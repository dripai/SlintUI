import {
    Theme, ThemeMode, Density, Direction, ControlSize,
    Typography, TypographyStyle, Label, Icon, IconSize, Surface, SurfaceVariant, Divider, FocusRing,
    ScrollArea, Stack, Space, Card,
    Button, ButtonVariant, IconButton, ToolButton, Toolbar,
    Checkbox, CheckState, Switch, TextField, ValidationState, Select, SegmentedControl,
    FormRow, SettingsSection, Tooltip, Progress, Spinner, EmptyState, EmptyStateKind, StatusBar, StatusTone,
    SplitPane, Tabs, TabItem, PopupMenu, PopupMenuEntry, Table, Tree, TreeItem, Form, FormError,
    Toast, ToastMessage, ToastTone,
    SplitButton, Breadcrumb, BreadcrumbItem, Steps, StepItem, StepState, Pagination, NavigationRail, NavigationRailItem, CommandPalette, CommandItem,
    MultiSelect, MultiSelectOption, AutoComplete, AutoCompleteOption, DatePicker, DateValue, TimePicker, TimeValue, ColorPicker, ColorOption,
    Avatar, DataGrid, Statistic, StatisticTone, Timeline, TimelineItem, TimelineTone, ImageView, ImageViewState, Calendar, CalendarDay,
    Notification, NotificationTone, Drawer, DrawerSide, Skeleton,
} from "@slint-ui/index.slint";
import { ListView } from "std-widgets.slint";
import { GalleryStrings } from "gallery-i18n.slint";
import { ComponentDetail } from "component-detail.slint";
import { GalleryNavigation } from "gallery-navigation.slint";
export { P1InteractionHarness } from "p1-interaction-harness.slint";
export { ModalDialog, ConfirmDialog } from "@slint-ui/index.slint";
import { IconCatalog } from "@slint-ui/icons/catalog.slint";
import { BellOutlined } from "@slint-ui/icons/outlined/bell.slint";
import { CheckOutlined } from "@slint-ui/icons/outlined/check.slint";
import { CloseOutlined } from "@slint-ui/icons/outlined/close.slint";
import { SearchOutlined } from "@slint-ui/icons/outlined.slint";
import { SettingOutlined } from "@slint-ui/icons/outlined/setting.slint";
import { UserOutlined } from "@slint-ui/icons/outlined/user.slint";
import { DotNetOutlined } from "@slint-ui/icons/outlined/dot-net.slint";
import { HeartFilled } from "@slint-ui/icons/filled/heart.slint";
import { StarFilled } from "@slint-ui/icons/filled.slint";
import { TwitchFilled } from "@slint-ui/icons/filled/twitch.slint";
import { XFilled } from "@slint-ui/icons/filled/x.slint";

export component GalleryWindow inherits Window {
    title: GalleryStrings.title;
    preferred-width: 1180px;
    preferred-height: 800px;
    min-width: 840px;
    min-height: 600px;
    background: Theme.bg-layout;

    in-out property <int> page: 0;
    in-out property <int> section: 0;
    in-out property <ThemeMode> theme-mode <=> Theme.mode;
    in-out property <Density> density-mode <=> Theme.density;
    in-out property <Direction> layout-direction <=> Theme.direction;
    in-out property <string> locale <=> Theme.locale;
    in-out property <float> preview-scale <=> Theme.preview-scale;
    in-out property <bool> reduced-motion <=> Theme.reduced-motion;
    in-out property <int> icon-style: 0;
    private property <bool> p2-drawer-open: false;
    private property <bool> p2-palette-open: false;
    private property <CheckState> checkbox-state: CheckState.checked;
    private property <bool> switch-value: true;
    private property <string> user-name: "SlintUI";
    private property <[string]> locale-options: ["简体中文", "English", "العربية"];
    private property <[string]> select-options: ["Alpha", "Beta", "Gamma"];
    private property <[string]> theme-options: [GalleryStrings.light, GalleryStrings.dark, GalleryStrings.contrast];
    private property <[string]> density-options: [GalleryStrings.compact, GalleryStrings.regular, GalleryStrings.comfortable];
    private property <[string]> scale-options: ["1×", "1.25×", "1.5×", "2×"];
    private property <[TabItem]> p1-tabs: [
        { text: GalleryStrings.overview, accessible-name: GalleryStrings.overview, enabled: true, closable: false },
        { text: GalleryStrings.details, accessible-name: GalleryStrings.details, enabled: true, closable: true },
        { text: GalleryStrings.disabled, accessible-name: GalleryStrings.disabled, enabled: false, closable: false },
    ];
    private property <[PopupMenuEntry]> menu-entries: [
        { text: GalleryStrings.add, shortcut: "Ctrl+N", enabled: true, checked: false, separator: false, has-submenu: false },
        { text: GalleryStrings.settings, shortcut: "", enabled: true, checked: true, separator: false, has-submenu: true },
        { text: "", shortcut: "", enabled: false, checked: false, separator: true, has-submenu: false },
        { text: GalleryStrings.delete-action, shortcut: "Del", enabled: false, checked: false, separator: false, has-submenu: false },
    ];
    private property <[TreeItem]> tree-items: [
        { text: GalleryStrings.settings, accessible-name: GalleryStrings.settings, level: 0, enabled: true, visible: true, has-children: true, expanded: true },
        { text: GalleryStrings.account, accessible-name: GalleryStrings.account, level: 1, enabled: true, visible: true, has-children: false, expanded: false },
        { text: GalleryStrings.notifications, accessible-name: GalleryStrings.notifications, level: 1, enabled: true, visible: true, has-children: false, expanded: false },
    ];
    private property <[TableColumn]> table-columns: [
        { title: GalleryStrings.user-name, min-width: 140px, width: 180px, horizontal-stretch: 1 },
        { title: GalleryStrings.validation, min-width: 120px, width: 160px, horizontal-stretch: 1 },
    ];
    private property <[[StandardListViewItem]]> table-rows: [
        [{ text: "SlintUI" }, { text: GalleryStrings.ready }],
        [{ text: "Desktop" }, { text: GalleryStrings.loading }],
    ];
    private property <[FormError]> form-errors: [
        { field: GalleryStrings.user-name, message: GalleryStrings.invalid-value },
    ];
    private property <[ToastMessage]> toast-messages: [
        { id: 1, text: GalleryStrings.ready, detail: GalleryStrings.long-text, tone: ToastTone.success, duration: 0ms, dismissible: true },
    ];
    private property <[BreadcrumbItem]> p2-breadcrumbs: [
        { text: GalleryStrings.foundations, accessible-name: GalleryStrings.foundations, enabled: true },
        { text: GalleryStrings.desktop, accessible-name: GalleryStrings.desktop, enabled: true },
        { text: "P2", accessible-name: "P2", enabled: false },
    ];
    private property <[StepItem]> p2-steps: [
        { title: GalleryStrings.one, description: GalleryStrings.ready, state: StepState.complete, enabled: true },
        { title: GalleryStrings.two, description: GalleryStrings.loading, state: StepState.current, enabled: true },
        { title: GalleryStrings.three, description: GalleryStrings.disabled, state: StepState.waiting, enabled: false },
    ];
    private property <[NavigationRailItem]> p2-rail-items: [
        { text: GalleryStrings.overview, icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/home.svg"), accessible-name: GalleryStrings.overview, enabled: true },
        { text: GalleryStrings.settings, icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/setting.svg"), accessible-name: GalleryStrings.settings, enabled: true },
    ];
    private property <[CommandItem]> p2-commands: [
        { text: GalleryStrings.search, description: GalleryStrings.long-text, shortcut: "Ctrl+K", enabled: true, visible: true },
        { text: GalleryStrings.settings, description: GalleryStrings.account-help, shortcut: "Ctrl+,", enabled: true, visible: true },
    ];
    private property <[MultiSelectOption]> p2-multi-options: [
        { text: "Alpha", selected: true, enabled: true }, { text: "Beta", selected: true, enabled: true }, { text: "Gamma", selected: false, enabled: true },
    ];
    private property <[AutoCompleteOption]> p2-suggestions: [
        { text: "SlintUI", detail: GalleryStrings.ready, enabled: true }, { text: "Slint", detail: "1.17.1", enabled: true },
    ];
    private property <[ColorOption]> p2-colors: [
        { name: "Primary", value: Theme.color-primary, enabled: true }, { name: "Success", value: Theme.color-success, enabled: true }, { name: "Error", value: Theme.color-error, enabled: true },
    ];
    private property <[TimelineItem]> p2-timeline: [
        { title: GalleryStrings.ready, detail: GalleryStrings.long-text, time: "09:30", tone: TimelineTone.success, enabled: true },
        { title: GalleryStrings.loading, detail: GalleryStrings.account-help, time: "10:00", tone: TimelineTone.info, enabled: true },
    ];
    private property <[string]> p2-weekdays: ["一", "二", "三", "四", "五", "六", "日"];
    private property <[CalendarDay]> p2-days: [
        { label: "1", accessible-name: "1", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "2", accessible-name: "2", in-current-month: true, selected: true, today: true, enabled: true },
        { label: "3", accessible-name: "3", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "4", accessible-name: "4", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "5", accessible-name: "5", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "6", accessible-name: "6", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "7", accessible-name: "7", in-current-month: true, selected: false, today: false, enabled: true },
    ];

    VerticalLayout {
        spacing: 0px;

        Surface {
            variant: SurfaceVariant.surface;
            bordered: true;
            radius: 0px;
            min-height: 104px;
            max-height: 104px;

            VerticalLayout {
                padding: Theme.space-3;
                spacing: Theme.space-2;

                Space {
                    Typography {
                        text: GalleryStrings.title;
                        style: TypographyStyle.title-medium;
                    }
                }

                Space {
                    Label { text: GalleryStrings.global; muted: true; min-width: 40px; wrap: no-wrap; }
                    SegmentedControl {
                        min-width: 200px;
                        max-width: 220px;
                        size: ControlSize.small;
                        options: root.theme-options;
                        selected-index: Theme.mode == ThemeMode.dark ? 1 : Theme.mode == ThemeMode.high-contrast ? 2 : 0;
                        selected(index, value) => { Theme.mode = index == 1 ? ThemeMode.dark : index == 2 ? ThemeMode.high-contrast : ThemeMode.light; }
                    }
                    Label { text: GalleryStrings.density; muted: true; min-width: 40px; wrap: no-wrap; }
                    SegmentedControl {
                        min-width: 260px;
                        max-width: 270px;
                        size: ControlSize.small;
                        options: root.density-options;
                        selected-index: Theme.density == Density.compact ? 0 : Theme.density == Density.comfortable ? 2 : 1;
                        selected(index, value) => { Theme.density = index == 0 ? Density.compact : index == 2 ? Density.comfortable : Density.regular; }
                    }
                    Label { text: GalleryStrings.scale; muted: true; min-width: 32px; wrap: no-wrap; }
                    SegmentedControl {
                        min-width: 240px;
                        max-width: 240px;
                        size: ControlSize.small;
                        options: root.scale-options;
                        selected-index: Theme.preview-scale == 1.25 ? 1 : Theme.preview-scale == 1.5 ? 2 : Theme.preview-scale == 2.0 ? 3 : 0;
                        selected(index, value) => { Theme.preview-scale = index == 1 ? 1.25 : index == 2 ? 1.5 : index == 3 ? 2.0 : 1.0; }
                    }
                    Label { text: GalleryStrings.locale; muted: true; min-width: 32px; wrap: no-wrap; }
                    Select {
                        min-width: 136px;
                        max-width: 152px;
                        accessible-name: GalleryStrings.locale;
                        model: root.locale-options;
                        current-index: Theme.locale == "en-US" ? 1 : Theme.locale == "ar-EG" ? 2 : 0;
                        selected(value) => {
                            Theme.locale = self.current-index == 1 ? "en-US" : self.current-index == 2 ? "ar-EG" : "zh-CN";
                            Theme.direction = self.current-index == 2 ? Direction.rtl : Direction.ltr;
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 0px;

            Surface {
                variant: SurfaceVariant.surface;
                radius: 0px;
                bordered: true;
                min-width: 220px;
                max-width: 220px;

                GalleryNavigation {
                    width: parent.width;
                    height: parent.height;
                    page <=> root.page;
                    section <=> root.section;
                    general-text: GalleryStrings.general;
                    layout-text: GalleryStrings.layout;
                    navigation-text: GalleryStrings.navigation;
                    data-entry-text: GalleryStrings.inputs;
                    data-display-text: GalleryStrings.data-display;
                    feedback-text: GalleryStrings.feedback;
                    icons-text: GalleryStrings.icons;
                }

            }

            detail-scroll := ScrollArea {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                mouse-drag-pan-enabled: false;
                viewport-width: preview.width;
                viewport-height: preview.height;

                preview := Rectangle {
                    width: max(detail-scroll.width, (840px + 2 * Theme.space-6) * Theme.preview-scale);
                    height: detail.content-height * Theme.preview-scale;

                    detail := ComponentDetail {
                        x: 0px;
                        y: 0px;
                        width: preview.width / Theme.preview-scale;
                        transform-origin: { x: 0px, y: 0px };
                        transform-scale-x: Theme.preview-scale * 100%;
                        transform-scale-y: Theme.preview-scale * 100%;
                        page: root.page;
                        section: root.section;
                        icon-style: root.icon-style;
                        drawer-requested => { root.p2-drawer-open = true; }
                        command-palette-requested => { root.p2-palette-open = true; }
                    }

                }
            }
        }

        StatusBar {
            text: GalleryStrings.ready;
            detail: Theme.locale + " · " + (Theme.direction == Direction.rtl ? "RTL" : "LTR") + " · " + round(Theme.preview-scale * 100) + "%";
            tone: StatusTone.info;
        }
    }

    CommandPalette {
        x: (root.width - self.width) / 2;
        y: 132px;
        open: root.p2-palette-open;
        commands: root.p2-commands;
        current-index: 0;
        accessible-name: "CommandPalette";
        placeholder-text: GalleryStrings.search;
        close-requested => { root.p2-palette-open = false; }
        selected(index) => { root.p2-palette-open = false; }
    }

    Drawer {
        width: root.width;
        height: root.height;
        open: root.p2-drawer-open;
        side: DrawerSide.end;
        title: GalleryStrings.details;
        close-accessible-name: GalleryStrings.cancel;
        close-requested => { root.p2-drawer-open = false; }
        Stack { padding: Theme.space-4; Typography { text: GalleryStrings.long-text; style: TypographyStyle.body; } }
    }
}

export component InteractionHarness inherits Window {
    width: 320px;
    height: 320px;
    out property <int> button-activations: 0;
    out property <int> disabled-button-activations: 0;
    out property <int> icon-button-activations: 0;
    out property <int> tool-button-activations: 0;
    out property <int> segmented-activations: 0;
    out property <int> text-field-edits: 0;
    out property <int> text-field-clears: 0;
    out property <int> select-activations: 0;
    out property <bool> tool-button-checked: test-tool-button.checked;
    out property <bool> checkbox-checked: test-checkbox.state == CheckState.checked;
    out property <bool> disabled-checkbox-checked: disabled-checkbox.state == CheckState.checked;
    out property <bool> switch-checked: test-switch.checked;
    out property <bool> disabled-switch-checked: disabled-switch.checked;
    out property <int> segmented-index: test-segmented.selected-index;
    out property <string> segmented-value: test-segmented.options[test-segmented.selected-index];
    out property <string> text-field-value: test-text-field.text;
    out property <string> disabled-text-field-value: disabled-text-field.text;
    out property <int> select-index: test-select.current-index;
    out property <string> select-value: test-select.current-value;
    out property <int> disabled-select-index: disabled-select.current-index;
    out property <int> p1-tab-index: test-tabs.current-index;
    out property <int> p1-tab-activations: 0;
    out property <int> p1-tree-index: test-tree.current-index;
    out property <bool> p1-tree-expanded: test-tree.items[0].expanded;
    out property <int> p1-tree-toggles: 0;
    out property <float> p1-split-ratio: test-split.ratio;
    out property <int> p1-split-changes: 0;
    out property <int> p1-menu-selections: 0;
    out property <int> p1-form-invalid-submits: 0;
    out property <int> p2-split-activations: 0;
    out property <int> p2-menu-activations: 0;
    out property <int> p2-breadcrumb-activations: 0;
    out property <int> p2-step-index: test-p2-steps.current-index;
    out property <int> p2-step-activations: 0;
    out property <int> p2-page: test-p2-pagination.current-page;
    out property <int> p2-page-activations: 0;
    out property <int> p2-rail-index: test-p2-rail.current-index;
    out property <int> p2-rail-activations: 0;
    out property <int> p2-command-activations: 0;
    out property <int> p2-multi-activations: 0;
    out property <int> p2-auto-index: test-p2-auto.current-index;
    out property <string> p2-auto-value: test-p2-auto.text;
    out property <int> p2-auto-activations: 0;
    out property <int> p2-date-year: test-p2-date.value.year;
    out property <int> p2-date-month: test-p2-date.value.month;
    out property <int> p2-date-day: test-p2-date.value.day;
    out property <int> p2-date-activations: 0;
    out property <int> p2-time-hour: test-p2-time.value.hour;
    out property <int> p2-time-minute: test-p2-time.value.minute;
    out property <int> p2-time-activations: 0;
    out property <int> p2-color-activations: 0;
    out property <int> p2-range-requests: 0;
    out property <int> p2-edit-requests: 0;
    out property <int> p2-calendar-activations: 0;

    public function activate-button() { test-button.activate(); }
    public function activate-disabled-button() { disabled-button.activate(); }
    public function activate-icon-button() { test-icon-button.activate(); }
    public function activate-tool-button() { test-tool-button.activate(); }
    public function toggle-checkbox() { test-checkbox.toggle(); }
    public function toggle-disabled-checkbox() { disabled-checkbox.toggle(); }
    public function toggle-switch() { test-switch.toggle(); }
    public function toggle-disabled-switch() { disabled-switch.toggle(); }
    public function select-segmented(index: int) { test-segmented.select(index); }
    public function clear-text-field() { test-text-field.clear(); }
    public function clear-disabled-text-field() { disabled-text-field.clear(); }
    public function select-option(index: int) { test-select.select-index(index); }
    public function select-disabled-option(index: int) { disabled-select.select-index(index); }
    public function select-p1-tab(index: int) { test-tabs.select(index); }
    public function select-p1-tree(index: int) { test-tree.select(index); }
    public function toggle-p1-tree(index: int) { test-tree.toggle(index); }
    public function set-p1-split-ratio(value: float) { test-split.set-ratio(value); }
    public function activate-p1-menu(index: int) { test-menu.activate(index); }
    public function submit-invalid-p1-form() { test-form.submit-form(); }
    public function activate-p2-split() { test-p2-split.activate(); }
    public function activate-p2-split-menu(index: int) { test-p2-split.activate-menu(index); }
    public function select-p2-breadcrumb(index: int) { test-p2-breadcrumb.select(index); }
    public function select-p2-step(index: int) { test-p2-steps.select(index); }
    public function select-p2-page(page: int) { test-p2-pagination.select-page(page); }
    public function select-p2-rail(index: int) { test-p2-rail.select(index); }
    public function activate-p2-command(index: int) { test-p2-command.activate(index); }
    public function request-p2-multi(index: int, selected: bool) { test-p2-multi.request-selection(index, selected); }
    public function choose-p2-auto(index: int) { test-p2-auto.choose(index); }
    public function select-p2-date(year: int, month: int, day: int) { test-p2-date.select(year, month, day); }
    public function select-p2-time(hour: int, minute: int, second: int) { test-p2-time.select(hour, minute, second); }
    public function select-p2-color(index: int) { test-p2-color.select(index); }
    public function request-p2-range(start: int, count: int) { test-p2-grid.request-range(start, count); }
    public function request-p2-edit(row: int, column: int) { test-p2-grid.request-edit(row, column); }
    public function select-p2-calendar(index: int) { test-p2-calendar.select(index); }

    Stack {
        test-button := Button {
            text: "Test";
            clicked => { root.button-activations += 1; }
        }
        disabled-button := Button {
            text: "Disabled";
            enabled: false;
            clicked => { root.disabled-button-activations += 1; }
        }
        test-icon-button := IconButton {
            icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/plus.svg");
            accessible-name: "Icon action";
            clicked => { root.icon-button-activations += 1; }
        }
        test-tool-button := ToolButton {
            text: "Tool";
            checkable: true;
            clicked => { root.tool-button-activations += 1; }
        }
        test-checkbox := Checkbox { text: "Test checkbox"; state: CheckState.indeterminate; }
        disabled-checkbox := Checkbox { text: "Disabled checkbox"; enabled: false; }
        test-switch := Switch { text: "Test switch"; }
        disabled-switch := Switch { text: "Disabled switch"; enabled: false; }
        test-segmented := SegmentedControl {
            options: ["One", "Two", "Three"];
            selected(index, value) => { root.segmented-activations += 1; }
        }
        test-text-field := TextField {
            text: "Initial";
            clearable: true;
            clear-accessible-name: "Clear";
            edited(value) => { root.text-field-edits += 1; }
            cleared => { root.text-field-clears += 1; }
        }
        disabled-text-field := TextField {
            text: "Locked";
            clearable: true;
            enabled: false;
            clear-accessible-name: "Clear";
        }
        test-select := Select {
            model: ["Alpha", "Beta", "Gamma"];
            selected(value) => { root.select-activations += 1; }
        }
        disabled-select := Select {
            model: ["Alpha", "Beta"];
            enabled: false;
        }
        test-tabs := Tabs {
            tabs: [
                { text: "One", accessible-name: "One", enabled: true, closable: false },
                { text: "Two", accessible-name: "Two", enabled: true, closable: false },
                { text: "Disabled", accessible-name: "Disabled", enabled: false, closable: false },
            ];
            selected(index) => { root.p1-tab-activations += 1; }
        }
        test-tree := Tree {
            items: [
                { text: "Root", accessible-name: "Root", level: 0, enabled: true, visible: true, has-children: true, expanded: false },
                { text: "Child", accessible-name: "Child", level: 1, enabled: true, visible: true, has-children: false, expanded: false },
            ];
            expanded-changed(index, expanded) => { root.p1-tree-toggles += 1; }
        }
        test-split := SplitPane {
            width: 300px;
            height: 100px;
            changed(value) => { root.p1-split-changes += 1; }
        }
        test-menu := PopupMenu {
            entries: [
                { text: "Open", shortcut: "", enabled: true, checked: false, separator: false, has-submenu: false },
                { text: "Disabled", shortcut: "", enabled: false, checked: false, separator: false, has-submenu: false },
            ];
            selected(index) => { root.p1-menu-selections += 1; }
        }
        test-form := Form {
            errors: [{ field: "Name", message: "Required" }];
            invalid-submit(index) => { root.p1-form-invalid-submits += 1; }
        }
        test-p2-split := SplitButton {
            text: "Save";
            menu-entries: [
                { text: "Open", shortcut: "", enabled: true, checked: false, separator: false, has-submenu: false },
                { text: "Disabled", shortcut: "", enabled: false, checked: false, separator: false, has-submenu: false },
            ];
            clicked => { root.p2-split-activations += 1; }
            menu-selected(index) => { root.p2-menu-activations += 1; }
        }
        test-p2-breadcrumb := Breadcrumb {
            items: [
                { text: "Root", accessible-name: "Root", enabled: true },
                { text: "Current", accessible-name: "Current", enabled: true },
            ];
            selected(index) => { root.p2-breadcrumb-activations += 1; }
        }
        test-p2-steps := Steps {
            steps: [
                { title: "One", description: "", state: StepState.current, enabled: true },
                { title: "Two", description: "", state: StepState.waiting, enabled: true },
                { title: "Disabled", description: "", state: StepState.waiting, enabled: false },
            ];
            selected(index) => { root.p2-step-activations += 1; }
        }
        test-p2-pagination := Pagination { current-page: 1; page-count: 5; changed(page) => { root.p2-page-activations += 1; } }
        test-p2-rail := NavigationRail {
            items: [
                { text: "One", icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/home.svg"), accessible-name: "One", enabled: true },
                { text: "Two", icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/setting.svg"), accessible-name: "Two", enabled: true },
                { text: "Disabled", icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/stop.svg"), accessible-name: "Disabled", enabled: false },
            ];
            selected(index) => { root.p2-rail-activations += 1; }
        }
        test-p2-command := CommandPalette {
            commands: [
                { text: "Open", description: "", shortcut: "", enabled: true, visible: true },
                { text: "Disabled", description: "", shortcut: "", enabled: false, visible: true },
            ];
            selected(index) => { root.p2-command-activations += 1; }
        }
        test-p2-multi := MultiSelect {
            options: [
                { text: "One", selected: false, enabled: true },
                { text: "Disabled", selected: false, enabled: false },
            ];
            selection-requested(index, selected) => { root.p2-multi-activations += 1; }
        }
        test-p2-auto := AutoComplete {
            suggestions: [
                { text: "Slint", detail: "", enabled: true },
                { text: "Disabled", detail: "", enabled: false },
            ];
            selected(index, value) => { root.p2-auto-activations += 1; }
        }
        test-p2-date := DatePicker { value: { year: 2026, month: 7, day: 20 }; changed(value) => { root.p2-date-activations += 1; } }
        test-p2-time := TimePicker { value: { hour: 9, minute: 30, second: 0 }; changed(value) => { root.p2-time-activations += 1; } }
        test-p2-color := ColorPicker {
            options: [{ name: "Blue", value: Theme.color-primary, enabled: true }, { name: "Disabled", value: Theme.text-primary, enabled: false }];
            changed(index, value) => { root.p2-color-activations += 1; }
        }
        test-p2-grid := DataGrid {
            total-row-count: 100;
            editable: true;
            columns: [{ title: "Name", min-width: 80px, width: 120px, horizontal-stretch: 1 }];
            rows: [[{ text: "SlintUI" }]];
            range-requested(start, count) => { root.p2-range-requests += 1; }
            edit-requested(row, column) => { root.p2-edit-requests += 1; }
        }
        test-p2-calendar := Calendar {
            days: [
                { label: "1", accessible-name: "1", in-current-month: true, selected: false, today: false, enabled: true },
                { label: "2", accessible-name: "2", in-current-month: true, selected: false, today: false, enabled: false },
            ];
            selected(index) => { root.p2-calendar-activations += 1; }
        }
    }
}
