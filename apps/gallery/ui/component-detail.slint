            if root.page == 1 && root.section == 11: Grid { width: 720px; Row { Surface { min-height: 72px; bordered: true; } Surface { min-height: 72px; bordered: true; } } Row { Surface { min-height: 72px; bordered: true; } Surface { min-height: 72px; bordered: true; } } }
            if root.page == 1 && root.section == 12: Panel { width: 620px; title: GalleryStrings.settings; description: GalleryStrings.account-help; Stack { padding: Theme.space-4; Label { text: GalleryStrings.long-text; } Button { text: GalleryStrings.save; variant: ButtonVariant.primary; } } }
            if root.page == 1 && root.section == 13: shell := AppShell { width: 720px; height: 300px; Label { x: shell.title-x + Theme.space-3; y: shell.title-y; width: shell.title-width - Theme.space-6; height: shell.title-height; text: GalleryStrings.title; } Label { x: shell.navigation-x + Theme.space-3; y: shell.navigation-y + Theme.space-3; width: shell.navigation-width - Theme.space-6; text: GalleryStrings.navigation; } Label { x: shell.content-x + Theme.space-4; y: shell.content-y + Theme.space-4; width: shell.content-width - Theme.space-8; text: GalleryStrings.long-text; wrap: word-wrap; } Label { x: shell.status-x + Theme.space-3; y: shell.status-y; width: shell.status-width - Theme.space-6; height: shell.status-height; text: GalleryStrings.ready; } }
