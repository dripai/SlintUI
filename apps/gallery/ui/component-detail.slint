import {
    Theme, ThemeMode, Density, ControlSize,
    Typography, TypographyStyle, Label, Icon, IconSize, Surface, SurfaceVariant, Divider, DividerOrientation, FocusRing,
    ScrollArea, Stack, Space, Card, Overlay, SplitPane, SettingsSection, FormRow, Form, FormError, Toolbar,
    Button, ButtonVariant, IconButton, ToolButton, SplitButton,
    Checkbox, CheckState, Switch, TextField, ValidationState, Select, SegmentedControl,
    MultiSelect, MultiSelectOption, AutoComplete, AutoCompleteOption, DatePicker, TimePicker, ColorPicker, ColorOption,
    Tabs, TabItem, PopupMenu, PopupMenuEntry, ContextMenu, Breadcrumb, BreadcrumbItem, Steps, StepItem, StepState, Pagination, NavigationRail, NavigationRailItem, CommandPalette, CommandItem,
    Table, Tree, TreeItem, Avatar, DataGrid, Statistic, StatisticTone, Timeline, TimelineItem, TimelineTone, ImageView, ImageViewState, Calendar, CalendarDay, EmptyState, EmptyStateKind,
    Tooltip, Progress, Spinner, StatusBar, StatusTone, Toast, ToastMessage, ToastTone, Notification, NotificationTone, Drawer, DrawerSide, Skeleton,
} from "@slint-ui/index.slint";
import { ListView } from "std-widgets.slint";
import { GalleryStrings } from "gallery-i18n.slint";
import { IconCatalog } from "@slint-ui/icons/catalog.slint";
import { BellOutlined } from "@slint-ui/icons/outlined/bell.slint";
import { SearchOutlined } from "@slint-ui/icons/outlined/search.slint";
import { SettingOutlined } from "@slint-ui/icons/outlined/setting.slint";
import { UserOutlined } from "@slint-ui/icons/outlined/user.slint";

export component ComponentDetail inherits Rectangle {
    in property <int> page: 0;
    in property <int> section: 0;
    in property <int> icon-style: 0;
    callback drawer-requested();
    callback command-palette-requested();

    private property <string> general-name: section == 0 ? "Theme" : section == 1 ? "Typography" : section == 2 ? "Label" : section == 3 ? "Icon" : section == 4 ? "Surface" : section == 5 ? "Divider" : section == 6 ? "FocusRing" : section == 7 ? "Button" : section == 8 ? "IconButton" : section == 9 ? "ToolButton" : "SplitButton";
    private property <string> layout-name: section == 0 ? "Surface" : section == 1 ? "Divider" : section == 2 ? "FocusRing" : section == 3 ? "Stack" : section == 4 ? "Space" : section == 5 ? "ScrollArea" : section == 6 ? "Overlay" : section == 7 ? "SplitPane" : section == 8 ? "Toolbar" : "SettingsSection";
    private property <string> entry-name: section == 0 ? "Form" : section == 1 ? "FormRow" : section == 2 ? "Checkbox" : section == 3 ? "Switch" : section == 4 ? "TextField" : section == 5 ? "Select" : section == 6 ? "MultiSelect" : section == 7 ? "AutoComplete" : section == 8 ? "DatePicker" : section == 9 ? "TimePicker" : "ColorPicker";
    private property <string> navigation-name: section == 0 ? "Tabs" : section == 1 ? "PopupMenu" : section == 2 ? "ContextMenu" : section == 3 ? "Breadcrumb" : section == 4 ? "Steps" : section == 5 ? "Pagination" : section == 6 ? "NavigationRail" : "CommandPalette";
    private property <string> display-name: section == 0 ? "Card" : section == 1 ? "SegmentedControl" : section == 2 ? "Tooltip" : section == 3 ? "Table" : section == 4 ? "Tree" : section == 5 ? "Avatar" : section == 6 ? "DataGrid" : section == 7 ? "Statistic" : section == 8 ? "Timeline" : section == 9 ? "ImageView" : section == 10 ? "Calendar" : "EmptyState";
    private property <string> feedback-name: section == 0 ? "Progress" : section == 1 ? "Spinner" : section == 2 ? "StatusBar" : section == 3 ? "Toast" : section == 4 ? "ModalDialog" : section == 5 ? "ConfirmDialog" : section == 6 ? "Notification" : section == 7 ? "Drawer" : "Skeleton";
    private property <string> selected-name: page == 0 ? general-name : page == 1 ? layout-name : page == 2 ? "Button" : page == 3 ? entry-name : page == 4 ? feedback-name : page == 5 ? (section == 0 ? "Outlined Icons" : "Filled Icons") : page == 6 ? navigation-name : display-name;
    private property <bool> button-page: (page == 0 && section == 7) || page == 2;
    private property <CheckState> checkbox-state: CheckState.checked;
    private property <bool> switch-value: true;
    private property <string> input-value: "SlintUI";
    private property <[string]> options: ["Alpha", "Beta", "Gamma"];
    private property <[PopupMenuEntry]> menu-entries: [
        { text: GalleryStrings.add, shortcut: "Ctrl+N", enabled: true, checked: false, separator: false, has-submenu: false },
        { text: GalleryStrings.settings, shortcut: "", enabled: true, checked: true, separator: false, has-submenu: false },
        { text: GalleryStrings.delete-action, shortcut: "Del", enabled: false, checked: false, separator: false, has-submenu: false },
    ];
    private property <[TabItem]> tabs: [
        { text: GalleryStrings.overview, accessible-name: GalleryStrings.overview, enabled: true, closable: false },
        { text: GalleryStrings.details, accessible-name: GalleryStrings.details, enabled: true, closable: true },
        { text: GalleryStrings.disabled, accessible-name: GalleryStrings.disabled, enabled: false, closable: false },
    ];
    private property <[BreadcrumbItem]> breadcrumbs: [
        { text: GalleryStrings.general, accessible-name: GalleryStrings.general, enabled: true },
        { text: GalleryStrings.navigation, accessible-name: GalleryStrings.navigation, enabled: true },
        { text: selected-name, accessible-name: selected-name, enabled: false },
    ];
    private property <[StepItem]> steps: [
        { title: GalleryStrings.one, description: GalleryStrings.ready, state: StepState.complete, enabled: true },
        { title: GalleryStrings.two, description: GalleryStrings.loading, state: StepState.current, enabled: true },
        { title: GalleryStrings.three, description: GalleryStrings.disabled, state: StepState.waiting, enabled: false },
    ];
    private property <[NavigationRailItem]> rail-items: [
        { text: GalleryStrings.overview, icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/home.svg"), accessible-name: GalleryStrings.overview, enabled: true },
        { text: GalleryStrings.settings, icon: SettingOutlined.source, accessible-name: GalleryStrings.settings, enabled: true },
    ];
    private property <[MultiSelectOption]> multi-options: [
        { text: "Alpha", selected: true, enabled: true }, { text: "Beta", selected: true, enabled: true }, { text: "Gamma", selected: false, enabled: true },
    ];
    private property <[AutoCompleteOption]> suggestions: [
        { text: "SlintUI", detail: GalleryStrings.ready, enabled: true }, { text: "Slint", detail: "1.17.1", enabled: true },
    ];
    private property <[ColorOption]> colors: [
        { name: "Primary", value: Theme.color-primary, enabled: true }, { name: "Success", value: Theme.color-success, enabled: true }, { name: "Error", value: Theme.color-error, enabled: true },
    ];
    private property <[TreeItem]> tree-items: [
        { text: GalleryStrings.settings, accessible-name: GalleryStrings.settings, level: 0, enabled: true, visible: true, has-children: true, expanded: true },
        { text: GalleryStrings.account, accessible-name: GalleryStrings.account, level: 1, enabled: true, visible: true, has-children: false, expanded: false },
    ];
    private property <[TableColumn]> columns: [
        { title: GalleryStrings.user-name, min-width: 140px, width: 180px, horizontal-stretch: 1 },
        { title: GalleryStrings.validation, min-width: 120px, width: 160px, horizontal-stretch: 1 },
    ];
    private property <[[StandardListViewItem]]> rows: [
        [{ text: "SlintUI" }, { text: GalleryStrings.ready }], [{ text: "Desktop" }, { text: GalleryStrings.loading }],
    ];
    private property <[TimelineItem]> timeline-items: [
        { title: GalleryStrings.ready, detail: GalleryStrings.long-text, time: "09:30", tone: TimelineTone.success, enabled: true },
        { title: GalleryStrings.loading, detail: GalleryStrings.account-help, time: "10:00", tone: TimelineTone.info, enabled: true },
    ];
    private property <[string]> weekdays: ["一", "二", "三", "四", "五", "六", "日"];
    private property <[CalendarDay]> days: [
        { label: "1", accessible-name: "1", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "2", accessible-name: "2", in-current-month: true, selected: true, today: true, enabled: true },
        { label: "3", accessible-name: "3", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "4", accessible-name: "4", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "5", accessible-name: "5", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "6", accessible-name: "6", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "7", accessible-name: "7", in-current-month: true, selected: false, today: false, enabled: true },
    ];
    private property <[ToastMessage]> toasts: [
        { id: 1, text: GalleryStrings.ready, detail: GalleryStrings.long-text, tone: ToastTone.success, duration: 0ms, dismissible: true },
    ];

    out property <length> content-height: content.preferred-height;
    min-width: 680px;
    height: root.content-height;

    content := Stack {
        width: parent.width;
        padding: Theme.space-6;
        gap: Theme.space-4;

        Typography { text: root.selected-name; style: TypographyStyle.title-large; }
        Typography { text: root.button-page ? GalleryStrings.button-description : GalleryStrings.component-description; style: TypographyStyle.body; color: Theme.text-secondary; }
        Typography { text: GalleryStrings.when-to-use; style: TypographyStyle.title-small; }
        Typography { text: root.button-page ? GalleryStrings.button-when-to-use : GalleryStrings.component-when-to-use; style: TypographyStyle.body; }
        Typography { text: GalleryStrings.examples; style: TypographyStyle.title-small; }

        Card {
            width: 840px;
            title: root.button-page ? GalleryStrings.types : GalleryStrings.basic-example;
            description: root.button-page ? GalleryStrings.button-types-help : GalleryStrings.basic-example-help;

            if root.page == 0 && root.section == 0: Stack {
                Space { Label { text: GalleryStrings.theme; muted: true; } Label { text: Theme.mode == ThemeMode.dark ? GalleryStrings.dark : Theme.mode == ThemeMode.high-contrast ? GalleryStrings.contrast : GalleryStrings.light; } }
                Space { Label { text: GalleryStrings.density; muted: true; } Label { text: Theme.density == Density.compact ? GalleryStrings.compact : Theme.density == Density.comfortable ? GalleryStrings.comfortable : GalleryStrings.regular; } }
                Space { Rectangle { width: 64px; height: 32px; background: Theme.color-primary; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-success; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-warning; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-error; border-radius: Theme.radius-medium; } }
            }
            if root.page == 0 && root.section == 1: Stack { Typography { text: GalleryStrings.title; style: TypographyStyle.title-large; } Typography { text: GalleryStrings.subtitle; style: TypographyStyle.title-medium; } Typography { text: GalleryStrings.long-text; style: TypographyStyle.body; } Typography { text: "Caption · 12 / 20"; style: TypographyStyle.caption; color: Theme.text-secondary; } }
            if root.page == 0 && root.section == 2: Stack { Label { text: GalleryStrings.long-text; } Label { text: GalleryStrings.disabled; muted: true; } }
            if root.page == 0 && root.section == 3: Space { Icon { source: SettingOutlined.source; size: IconSize.large; accessible-name: GalleryStrings.settings; } Icon { source: BellOutlined.source; size: IconSize.medium; accessible-name: GalleryStrings.notifications; } Icon { source: SearchOutlined.source; size: IconSize.small; accessible-name: GalleryStrings.search; } Icon { source: UserOutlined.source; size: IconSize.medium; accessible-name: GalleryStrings.user-name; } }
            if root.page == 0 && root.section == 4: Space { Surface { width: 180px; height: 88px; variant: SurfaceVariant.surface; bordered: true; } Surface { width: 180px; height: 88px; variant: SurfaceVariant.elevated; bordered: true; } Surface { width: 180px; height: 88px; variant: SurfaceVariant.layout; bordered: true; } }
            if root.page == 0 && root.section == 5: Stack { Divider { orientation: DividerOrientation.horizontal; } Space { Label { text: GalleryStrings.one; } Divider { orientation: DividerOrientation.vertical; } Label { text: GalleryStrings.two; } } }
            if root.page == 0 && root.section == 6: Rectangle { width: 180px; height: 48px; background: Theme.bg-control; border-radius: Theme.radius-medium; FocusRing { active: true; target-width: parent.width; target-height: parent.height; } }
            if root.button-page: Space { Button { text: GalleryStrings.save; variant: ButtonVariant.primary; } Button { text: GalleryStrings.cancel; } Button { text: GalleryStrings.delete-action; variant: ButtonVariant.danger; } Button { text: GalleryStrings.text-action; variant: ButtonVariant.text; } Button { text: GalleryStrings.link-action; variant: ButtonVariant.link; } }
            if root.page == 0 && root.section == 8: Space { IconButton { icon: SearchOutlined.source; accessible-name: GalleryStrings.search; tooltip: GalleryStrings.search; } IconButton { icon: SettingOutlined.source; accessible-name: GalleryStrings.settings; enabled: false; } }
            if root.page == 0 && root.section == 9: Space { ToolButton { text: GalleryStrings.save; checkable: true; checked: true; } ToolButton { text: GalleryStrings.notifications; } ToolButton { text: GalleryStrings.disabled; enabled: false; } }
            if root.page == 0 && root.section == 10: Stack { SplitButton { text: GalleryStrings.save; variant: ButtonVariant.primary; menu-entries: root.menu-entries; menu-accessible-name: GalleryStrings.open-menu; } SplitButton { text: GalleryStrings.loading; loading: true; menu-entries: root.menu-entries; menu-accessible-name: GalleryStrings.open-menu; } }

            if root.page == 1 && root.section == 0: Space { Surface { width: 220px; height: 96px; bordered: true; } Surface { width: 220px; height: 96px; variant: SurfaceVariant.elevated; bordered: true; } }
            if root.page == 1 && root.section == 1: Stack { Divider { orientation: DividerOrientation.horizontal; } Space { Label { text: GalleryStrings.one; } Divider { orientation: DividerOrientation.vertical; } Label { text: GalleryStrings.two; } } }
            if root.page == 1 && root.section == 2: Rectangle { width: 180px; height: 48px; background: Theme.bg-control; border-radius: Theme.radius-medium; FocusRing { active: true; target-width: parent.width; target-height: parent.height; } }
            if root.page == 1 && root.section == 3: Stack { Button { text: GalleryStrings.one; } Button { text: GalleryStrings.two; } Button { text: GalleryStrings.three; } }
            if root.page == 1 && root.section == 4: Space { Button { text: GalleryStrings.one; } Button { text: GalleryStrings.two; } Button { text: GalleryStrings.three; } }
            if root.page == 1 && root.section == 5: ScrollArea { width: 420px; height: 180px; Stack { for value in 8: Label { text: GalleryStrings.details + " " + (value + 1); } } }
            if root.page == 1 && root.section == 6: Rectangle { width: 420px; height: 180px; background: Theme.bg-layout; Overlay { active: true; accessible-name: "Overlay"; Card { x: 100px; y: 48px; width: 220px; title: "Overlay"; Label { text: GalleryStrings.details; } } } }
            if root.page == 1 && root.section == 7: split := SplitPane { width: 720px; height: 240px; Surface { x: split.first-x; y: split.first-y; width: split.first-width; height: split.first-height; bordered: true; } Surface { x: split.second-x; y: split.second-y; width: split.second-width; height: split.second-height; bordered: true; } }
            if root.page == 1 && root.section == 8: Toolbar { accessible-name: GalleryStrings.sample-toolbar; IconButton { icon: SearchOutlined.source; accessible-name: GalleryStrings.search; } ToolButton { text: GalleryStrings.save; checkable: true; } Divider { orientation: DividerOrientation.vertical; } ToolButton { text: GalleryStrings.settings; } }
            if root.page == 1 && root.section == 9: SettingsSection { title: GalleryStrings.account; description: GalleryStrings.account-help; FormRow { label: GalleryStrings.user-name; TextField { text <=> root.input-value; accessible-name: GalleryStrings.user-name; } } }

            if root.page == 3 && root.section == 0: Form { width: 520px; errors: [{ field: GalleryStrings.user-name, message: GalleryStrings.invalid-value }]; error-summary-title: GalleryStrings.fix-errors; TextField { text: GalleryStrings.invalid-value; validation: ValidationState.error; } Button { text: GalleryStrings.save; variant: ButtonVariant.primary; } }
            if root.page == 3 && root.section == 1: FormRow { width: 620px; label: GalleryStrings.user-name; required: true; help-text: GalleryStrings.account-help; TextField { text <=> root.input-value; accessible-name: GalleryStrings.user-name; } }
            if root.page == 3 && root.section == 2: Stack { Checkbox { text: GalleryStrings.notifications; state <=> root.checkbox-state; } Checkbox { text: GalleryStrings.indeterminate; state: CheckState.indeterminate; } Checkbox { text: GalleryStrings.disabled; enabled: false; state: CheckState.checked; } }
            if root.page == 3 && root.section == 3: Stack { Switch { text: GalleryStrings.update; checked <=> root.switch-value; } Switch { text: GalleryStrings.disabled; enabled: false; } }
            if root.page == 3 && root.section == 4: Stack { TextField { width: 420px; text <=> root.input-value; placeholder-text: GalleryStrings.user-name-placeholder; clearable: true; clear-accessible-name: GalleryStrings.cancel; } TextField { width: 420px; text: GalleryStrings.invalid-value; validation: ValidationState.error; } TextField { width: 420px; text: GalleryStrings.disabled; enabled: false; } }
            if root.page == 3 && root.section == 5: Space { Select { model: root.options; current-index: 1; } Select { model: root.options; enabled: false; } }
            if root.page == 3 && root.section == 6: MultiSelect { width: 420px; options: root.multi-options; selected-labels: ["Alpha", "Beta"]; selected-summary: "Alpha, Beta"; placeholder-text: GalleryStrings.choose; }
            if root.page == 3 && root.section == 7: AutoComplete { width: 420px; text: "Slint"; suggestions: root.suggestions; placeholder-text: GalleryStrings.search; }
            if root.page == 3 && root.section == 8: DatePicker { value: { year: 2026, month: 7, day: 20 }; year-options: ["2025", "2026", "2027"]; year-values: [2025, 2026, 2027]; year-index: 1; month-options: ["06", "07", "08"]; month-values: [6, 7, 8]; month-index: 1; day-options: ["19", "20", "21"]; day-values: [19, 20, 21]; day-index: 1; }
            if root.page == 3 && root.section == 9: TimePicker { value: { hour: 9, minute: 30, second: 0 }; hour-options: ["08", "09", "10"]; hour-values: [8, 9, 10]; hour-index: 1; minute-options: ["00", "30"]; minute-values: [0, 30]; minute-index: 1; }
            if root.page == 3 && root.section == 10: ColorPicker { width: 280px; value: Theme.color-primary; value-label: "Primary"; options: root.colors; }

            if root.page == 6 && root.section == 0: Tabs { width: 620px; tabs: root.tabs; current-index: 0; }
            if root.page == 6 && root.section == 1: menu-anchor := Rectangle { width: 220px; height: Theme.control-height-medium; Button { width: parent.width; text: GalleryStrings.open-menu; clicked => { detail-menu.show(); } } detail-menu := PopupMenu { width: parent.width; height: parent.height; entries: root.menu-entries; } }
            if root.page == 6 && root.section == 2: context-anchor := Rectangle { width: 420px; height: 160px; background: Theme.bg-layout; border-radius: Theme.radius-medium; Label { x: Theme.space-4; y: Theme.space-4; text: "ContextMenu"; } ContextMenu { width: parent.width; height: parent.height; entries: root.menu-entries; } }
            if root.page == 6 && root.section == 3: Breadcrumb { items: root.breadcrumbs; }
            if root.page == 6 && root.section == 4: Steps { width: 720px; steps: root.steps; current-index: 1; }
            if root.page == 6 && root.section == 5: Pagination { current-page: 3; page-count: 12; page-size-options: ["10 / page", "20 / page"]; previous-accessible-name: GalleryStrings.previous; next-accessible-name: GalleryStrings.next; }
            if root.page == 6 && root.section == 6: NavigationRail { height: 220px; items: root.rail-items; current-index: 0; }
            if root.page == 6 && root.section == 7: Button { text: "CommandPalette"; clicked => { root.command-palette-requested(); } }

            if root.page == 7 && root.section == 0: Card { width: 420px; title: GalleryStrings.details; description: GalleryStrings.account-help; Label { text: GalleryStrings.long-text; } }
            if root.page == 7 && root.section == 1: SegmentedControl { width: 360px; options: root.options; selected-index: 1; }
            if root.page == 7 && root.section == 2: IconButton { icon: SettingOutlined.source; accessible-name: GalleryStrings.settings; tooltip: GalleryStrings.shortcut-help; }
            if root.page == 7 && root.section == 3: Table { width: 720px; height: 260px; columns: root.columns; rows: root.rows; empty-text: GalleryStrings.empty-title; }
            if root.page == 7 && root.section == 4: Tree { width: 420px; height: 240px; items: root.tree-items; }
            if root.page == 7 && root.section == 5: Space { Avatar { initials: "SU"; accessible-name: "SlintUI"; size: ControlSize.small; } Avatar { initials: "UI"; accessible-name: "UI"; } Avatar { initials: "SL"; accessible-name: "Slint"; size: ControlSize.large; } }
            if root.page == 7 && root.section == 6: DataGrid { width: 720px; height: 260px; columns: root.columns; rows: root.rows; total-row-count: 2048; empty-text: GalleryStrings.empty-title; }
            if root.page == 7 && root.section == 7: Space { Statistic { title: GalleryStrings.progress-label; value: "92"; suffix: "%"; tone: StatisticTone.positive; } Statistic { title: GalleryStrings.validation; value: "3"; tone: StatisticTone.negative; } }
            if root.page == 7 && root.section == 8: Timeline { width: 680px; items: root.timeline-items; }
            if root.page == 7 && root.section == 9: Space { ImageView { width: 260px; height: 220px; state: ImageViewState.empty; empty-text: GalleryStrings.empty-title; } ImageView { width: 260px; height: 220px; state: ImageViewState.error; error-text: GalleryStrings.invalid-value; } }
            if root.page == 7 && root.section == 10: Calendar { title: "2026-07"; weekday-labels: root.weekdays; days: root.days; previous-accessible-name: GalleryStrings.previous; next-accessible-name: GalleryStrings.next; }
            if root.page == 7 && root.section == 11: EmptyState { width: 520px; kind: EmptyStateKind.no-data; icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/inbox.svg"); title: GalleryStrings.empty-title; description: GalleryStrings.empty-description; Button { text: GalleryStrings.choose; variant: ButtonVariant.primary; } }

            if root.page == 4 && root.section == 0: Stack { Progress { width: 520px; value: 0.64; } Progress { width: 520px; indeterminate: true; } }
            if root.page == 4 && root.section == 1: Space { Spinner { accessible-name: GalleryStrings.loading; } Label { text: GalleryStrings.loading; } }
            if root.page == 4 && root.section == 2: StatusBar { width: 720px; text: GalleryStrings.ready; detail: "Slint 1.17.1"; tone: StatusTone.success; }
            if root.page == 4 && root.section == 3: Toast { messages: root.toasts; }
            if root.page == 4 && root.section == 4: Stack { Button { text: "ModalDialog"; } Typography { text: GalleryStrings.dialog-host-note; style: TypographyStyle.caption; color: Theme.text-secondary; } }
            if root.page == 4 && root.section == 5: Stack { Button { text: "ConfirmDialog"; variant: ButtonVariant.danger; } Typography { text: GalleryStrings.dialog-host-note; style: TypographyStyle.caption; color: Theme.text-secondary; } }
            if root.page == 4 && root.section == 6: Notification { title: GalleryStrings.notifications; message: GalleryStrings.long-text; tone: NotificationTone.info; action-text: GalleryStrings.details; close-accessible-name: GalleryStrings.cancel; }
            if root.page == 4 && root.section == 7: Button { text: "Drawer"; clicked => { root.drawer-requested(); } }
            if root.page == 4 && root.section == 8: Skeleton { width: 560px; rows: 3; show-avatar: true; accessible-name: GalleryStrings.loading; status-text: GalleryStrings.loading; }

            if root.page == 5: ListView {
                width: 760px;
                height: 460px;
                for entry[index] in root.section == 0 ? IconCatalog.outlined : IconCatalog.filled: Rectangle {
                    width: parent.width; height: Theme.row-height; background: Math.mod(index, 2) == 0 ? Theme.bg-surface : Theme.fill-hover;
                    HorizontalLayout { padding-left: Theme.space-3; padding-right: Theme.space-3; spacing: Theme.space-3; cross-axis-alignment: center; Icon { source: entry.source; size: IconSize.medium; accessible-name: entry.name; } Label { text: entry.name; } }
                }
            }
        }

        if root.button-page: Card {
            width: 840px;
            title: GalleryStrings.sizes-and-states;
            description: GalleryStrings.button-states-help;
            Stack {
                Space { Button { text: GalleryStrings.small; size: ControlSize.small; } Button { text: GalleryStrings.medium; size: ControlSize.medium; } Button { text: GalleryStrings.large; size: ControlSize.large; } }
                Space { Button { text: GalleryStrings.search; icon: SearchOutlined.source; } Button { text: GalleryStrings.loading; loading: true; variant: ButtonVariant.primary; } Button { text: GalleryStrings.disabled; enabled: false; } }
            }
        }

        Card {
            width: 840px;
            title: GalleryStrings.api-and-limits;
            description: GalleryStrings.api-help;
            Typography { text: GalleryStrings.component-api-note; style: TypographyStyle.body; color: Theme.text-secondary; }
        }

        Card {
            width: 840px;
            title: GalleryStrings.theme-token;
            description: GalleryStrings.theme-token-help;
            Typography { text: root.button-page ? "color-primary · color-error · control-height-small/medium/large · radius-medium · motion-fast" : "bg-surface · text-primary · border-default · radius-medium · space-2/3/4"; style: TypographyStyle.caption; color: Theme.text-secondary; }
        }
    }
}
