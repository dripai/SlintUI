import {
    Theme, ThemeMode, Density, ControlSize,
    Typography, TypographyStyle, Label, Icon, IconSize, Surface, SurfaceVariant, Divider, DividerOrientation, FocusRing,
    ScrollArea, Stack, Space, Card, Overlay, SplitPane, SettingsSection, FormRow, Form, FormError, Toolbar, Flex, Grid, Panel, AppShell, TitleBar,
    Button, ButtonVariant, IconButton, ToolButton, SplitButton, ButtonGroup, ButtonGroupItem, ToggleButton, Link, ShortcutHint,
    Checkbox, CheckState, Switch, TextField, ValidationState, Select, SegmentedControl, TextArea, SearchField, NumberInput, CheckboxGroup, CheckboxGroupItem, RadioGroup, RadioGroupItem, ComboBox, Slider, FilePicker,
    MultiSelect, MultiSelectOption, AutoComplete, AutoCompleteOption, DatePicker, TimePicker, ColorPicker, ColorOption,
    Tabs, TabItem, PopupMenu, PopupMenuEntry, ContextMenu, Dropdown, Breadcrumb, BreadcrumbItem, Steps, StepItem, StepState, Pagination, NavigationRail, NavigationRailItem, CommandPalette, CommandItem,
    Table, Tree, TreeItem, Avatar, DataGrid, Statistic, StatisticTone, Timeline, TimelineItem, TimelineTone, ImageView, ImageViewState, Calendar, CalendarDay, EmptyState, EmptyStateKind,
    Badge, BadgeTone, Tag, TagTone, List, ListItemData, DescriptionList, DescriptionItem, Collapse, CollapseItem, Popover,
    Tooltip, Progress, Spinner, StatusBar, StatusTone, Toast, ToastMessage, ToastTone, Notification, NotificationTone, Drawer, DrawerSide, Skeleton, Alert, AlertTone, ProgressRing, ResultState, ResultTone, LoadingOverlay,
} from "@slint-ui/index.slint";
import { ListView } from "std-widgets.slint";
import { GalleryStrings } from "gallery-i18n.slint";
import { IconCatalog } from "@slint-ui/icons/catalog.slint";
import { BellOutlined } from "@slint-ui/icons/outlined/bell.slint";
import { SearchOutlined } from "@slint-ui/icons/outlined/search.slint";
import { SettingOutlined } from "@slint-ui/icons/outlined/setting.slint";
import { UserOutlined } from "@slint-ui/icons/outlined/user.slint";

export component ComponentDetail inherits Rectangle {
    in property <int> page: 0;
    in property <int> section: 0;
    in property <int> icon-style: 0;
    callback drawer-requested();
    callback command-palette-requested();

    private property <string> general-name: section == 0 ? "Theme" : section == 1 ? "Typography" : section == 2 ? "Label" : section == 3 ? "Icon" : section == 4 ? "Surface" : section == 5 ? "Divider" : section == 6 ? "FocusRing" : section == 7 ? "Button" : section == 8 ? "IconButton" : section == 9 ? "ToolButton" : section == 10 ? "SplitButton" : section == 11 ? "ButtonGroup" : section == 12 ? "ToggleButton" : section == 13 ? "Link" : "ShortcutHint";
    private property <string> layout-name: section == 0 ? "Surface" : section == 1 ? "Divider" : section == 2 ? "FocusRing" : section == 3 ? "Stack" : section == 4 ? "Space" : section == 5 ? "ScrollArea" : section == 6 ? "Overlay" : section == 7 ? "SplitPane" : section == 8 ? "Toolbar" : section == 9 ? "SettingsSection" : section == 10 ? "Flex" : section == 11 ? "Grid" : section == 12 ? "Panel" : section == 13 ? "AppShell" : "TitleBar";
    private property <string> entry-name: section == 0 ? "Form" : section == 1 ? "FormRow" : section == 2 ? "Checkbox" : section == 3 ? "Switch" : section == 4 ? "TextField" : section == 5 ? "Select" : section == 6 ? "MultiSelect" : section == 7 ? "AutoComplete" : section == 8 ? "DatePicker" : section == 9 ? "TimePicker" : section == 10 ? "ColorPicker" : section == 11 ? "TextArea" : section == 12 ? "SearchField" : section == 13 ? "NumberInput" : section == 14 ? "CheckboxGroup" : section == 15 ? "RadioGroup" : section == 16 ? "ComboBox" : section == 17 ? "Slider" : "FilePicker";
    private property <string> navigation-name: section == 0 ? "Tabs" : section == 1 ? "PopupMenu" : section == 2 ? "ContextMenu" : section == 3 ? "Breadcrumb" : section == 4 ? "Steps" : section == 5 ? "Pagination" : section == 6 ? "NavigationRail" : section == 7 ? "CommandPalette" : "Dropdown";
    private property <string> display-name: section == 0 ? "Card" : section == 1 ? "SegmentedControl" : section == 2 ? "Tooltip" : section == 3 ? "Table" : section == 4 ? "Tree" : section == 5 ? "Avatar" : section == 6 ? "DataGrid" : section == 7 ? "Statistic" : section == 8 ? "Timeline" : section == 9 ? "ImageView" : section == 10 ? "Calendar" : section == 11 ? "EmptyState" : section == 12 ? "Badge" : section == 13 ? "Tag" : section == 14 ? "List" : section == 15 ? "DescriptionList" : section == 16 ? "Collapse" : "Popover";
    private property <string> feedback-name: section == 0 ? "Progress" : section == 1 ? "Spinner" : section == 2 ? "StatusBar" : section == 3 ? "Toast" : section == 4 ? "ModalDialog" : section == 5 ? "ConfirmDialog" : section == 6 ? "Notification" : section == 7 ? "Drawer" : section == 8 ? "Skeleton" : section == 9 ? "Alert" : section == 10 ? "ProgressRing" : section == 11 ? "ResultState" : "LoadingOverlay";
    private property <string> selected-name: page == 0 ? general-name : page == 1 ? layout-name : page == 2 ? "Button" : page == 3 ? entry-name : page == 4 ? feedback-name : page == 5 ? (section == 0 ? "Outlined Icons" : "Filled Icons") : page == 6 ? navigation-name : display-name;
    private property <[string]> general-api: [
        "mode · density · direction · locale · text-scale · preview-scale · reduced-motion",
        "text · style · color · horizontal-alignment · wrap · overflow",
        "text · muted · required · accessible-name · wrap · overflow",
        "source · size · color · accessible-name · rtl-mirror",
        "variant · bordered · radius · background-override",
        "orientation · color · inset-start · inset-end",
        "active · target-width · target-height · radius",
        "text · icon · variant · size · loading · checkable · checked · clicked()",
        "icon · size · enabled · loading · checked · accessible-name · clicked()",
        "text · icon · size · checkable · checked · enabled · clicked()",
        "text · variant · size · loading · menu-entries · clicked() · menu-selected()",
        "items · current-index · size · enabled · select() · select-next() · selected()",
        "text · icon · variant · size · enabled · checked · clicked()",
        "text · target · external · enabled · activate() · activated()",
        "shortcut · enabled · accessible-name",
    ];
    private property <[string]> layout-api: [
        "variant · bordered · radius · background-override", "orientation · color · inset-start · inset-end",
        "active · target-width · target-height · radius", "gap · padding · horizontal-alignment · @children",
        "gap · padding · vertical-alignment · @children", "viewport-width · viewport-height · mouse-drag-pan-enabled",
        "active · dismissible · accessible-name · dismiss-requested()", "orientation · ratio · min-first · min-second · collapsible · changed()",
        "accessible-name · enabled · @children", "title · description · @children",
        "gap · alignment · cross-axis-alignment · stretch constraints · @children",
        "horizontal-gap · vertical-gap · Row/cell layout constraints · @children",
        "title · description · bordered · accessible-name · @children",
        "title/navigation/content/status geometry · navigation-visible · @children",
        "title · icon · active · window button visibility · drag/minimize/maximize/restore/close callbacks",
    ];
    private property <[string]> entry-api: [
        "errors · enabled · submitting · valid · submit-form() · submitted()", "label · required · help-text · error-text · label-width · @children",
        "text · state · enabled · accessible-name · toggle() · toggled()", "text · checked · enabled · size · toggle() · toggled()",
        "text · placeholder-text · prefix-icon · suffix-icon · clearable · read-only · validation",
        "model · current-index · current-value · enabled · size · select-index() · selected()",
        "options · selected-labels · selected-summary · request-selection()", "text · suggestions · current-index · choose() · selected()",
        "value · year/month/day options · select() · changed()", "value · hour/minute/second options · select() · changed()",
        "value · value-label · options · select() · changed()",
        "text · placeholder-text · enabled · read-only · max-length · show-count · validation",
        "text · placeholder-text · clearable · submit() · searched()",
        "value · minimum · maximum · step-size · read-only · set-value() · step-by()",
        "items · enabled · error-text · set-checked() · changed()",
        "items · current-index · enabled · error-text · select() · select-next() · changed()",
        "text · suggestions · current-index · choose() · selected() · accepted()",
        "value · minimum · maximum · step · orientation · set-value() · changed()",
        "path · placeholder-text · browse-text · choose() · browse-requested() · changed()",
    ];
    private property <[string]> navigation-api: [
        "tabs · current-index · select() · select-next() · selected() · close-requested()",
        "entries · current-index · show() · close() · activate() · selected()",
        "entries · enabled · open-at-pointer() · selected() · closed()",
        "items · current-index · max-visible-items · select() · selected()",
        "steps · current-index · orientation · select() · selected()",
        "current-page · page-count · page-size-options · select-page() · changed()",
        "items · current-index · enabled · select() · selected()",
        "commands · query · current-index · open · activate() · selected()",
        "text · entries · enabled · size · toggle() · activate() · selected() · closed()",
    ];
    private property <[string]> display-api: [
        "title · description · @children", "options · selected-index · size · enabled · select() · selected()",
        "content · enabled · accessible-name · @children", "columns · rows · current-row · empty-text · selected() · sort-requested()",
        "items · current-index · select() · toggle() · selected() · expanded-changed()", "source · initials · size · accessible-name · fallback-icon",
        "columns · rows · row-offset · total-row-count · editable · request-range/edit()", "title · value · prefix · suffix · detail · tone",
        "items · pending-text · accessible-name", "source · state · fit · empty-text · error-text · retry-requested()",
        "title · weekday-labels · days · select() · previous/next-requested()", "kind · icon · title · description · accessible-name · @children",
        "count · max-count · show-zero · dot · tone · display-text",
        "text · tone · closable · selectable · selected · toggle()/close()",
        "items · current-index · enabled · empty-text · select() · select-next()",
        "items · label-width · bordered · accessible-name",
        "items · enabled · toggle() · changed()",
        "trigger-text · title · message · action-text · show()/close()/toggle()",
    ];
    private property <[string]> feedback-api: [
        "value · indeterminate · accessible-name", "size · indicator-color · accessible-name", "text · detail · tone · busy · accessible-name",
        "messages · accessible-name · dismiss-requested()", "dialog-title · message · accept-text · cancel-text · danger · busy · accept()/reject()",
        "dialog-title · message · accept-text · cancel-text · dangerous · busy · accept()/reject()", "title · message · tone · action-text · dismissible · busy",
        "open · side · title · dismissible · close-requested() · @children", "rows · show-avatar · active · accessible-name · status-text",
        "title · message · tone · dismissible · action-text · activate()/dismiss()",
        "value · indeterminate · show-value · accessible-name",
        "tone · title · description · accessible-name · @children",
        "active · text · cancelable · cancel-text · cancel() · cancel-requested()",
    ];
    private property <string> api-note: page == 0 ? general-api[section] : page == 1 ? layout-api[section] : page == 2 ? general-api[7] : page == 3 ? entry-api[section] : page == 4 ? feedback-api[section] : page == 5 ? "Per-icon source constant · Icon.source · Icon.size · Icon.color · accessible-name" : page == 6 ? navigation-api[section] : display-api[section];
    private property <string> state-note: selected-name == "Theme" ? "Light · Dark · High contrast · three densities · LTR/RTL · 100%–200%"
        : selected-name == "Typography" || selected-name == "Label" ? "Default · semantic color · wrapping · elision · long text · RTL"
        : selected-name == "Icon" ? "12/16/20/24px · semantic color · decorative/named · RTL mirror policy"
        : selected-name == "Surface" || selected-name == "Divider" || selected-name == "FocusRing" || selected-name == "Stack" || selected-name == "Space" || selected-name == "ScrollArea" ? "Default · density · long content · LTR/RTL · 100%–200%; interaction states do not apply"
        : selected-name == "Progress" || selected-name == "Spinner" || selected-name == "Skeleton" ? "Determinate/indeterminate where applicable · active · reduced motion · contrast themes"
        : selected-name == "ModalDialog" || selected-name == "ConfirmDialog" || selected-name == "Drawer" || selected-name == "Overlay" || selected-name == "PopupMenu" || selected-name == "ContextMenu" || selected-name == "CommandPalette" ? "Closed · open · focused · disabled item · repeated close · Escape/outside-close boundary"
        : selected-name == "TextField" || selected-name == "AutoComplete" || selected-name == "DatePicker" || selected-name == "TimePicker" || selected-name == "ColorPicker" || selected-name == "MultiSelect" ? "Default · focused · populated · empty · disabled · read-only/error where applicable · boundary input"
        : selected-name == "Table" || selected-name == "Tree" || selected-name == "DataGrid" || selected-name == "ImageView" ? "Default · selected · focused · empty · disabled/error where applicable · boundary request"
        : "Default · Hover · Pressed · Focused · Selected/Checked · Disabled · Loading/Error when applicable · long text";
    private property <string> token-note: selected-name == "Theme" ? "All semantic color, typography, spacing, radius, control, motion and component geometry tokens"
        : selected-name == "Typography" || selected-name == "Label" ? "font-size-* · line-height-* · font-weight-* · text-primary/secondary/disabled"
        : selected-name == "Icon" ? "icon-size-* · icon-default/hover · text-disabled · color-*"
        : selected-name == "Surface" || selected-name == "Card" ? "bg-surface/elevated/layout · border-* · radius-* · space-* · text-*"
        : selected-name == "Button" || selected-name == "IconButton" || selected-name == "ToolButton" || selected-name == "SplitButton" ? "control-height-* · control-padding-horizontal · color-primary/error-* · fill-* · radius-medium · motion-fast"
        : selected-name == "TextField" || selected-name == "Select" || selected-name == "MultiSelect" || selected-name == "AutoComplete" || selected-name == "DatePicker" || selected-name == "TimePicker" || selected-name == "ColorPicker" ? "control-height-* · control-min-width · border-default · focus-outline · validation colors · field-affix-slot"
        : selected-name == "Checkbox" || selected-name == "Switch" || selected-name == "SegmentedControl" ? "control-height-* · color-primary-* · selection-bg · border-default · focus-outline · radius-*"
        : selected-name == "ModalDialog" || selected-name == "ConfirmDialog" || selected-name == "Drawer" || selected-name == "Overlay" ? "overlay-mask · bg-elevated · dialog/drawer geometry · border-* · radius-* · space-*"
        : selected-name == "Progress" || selected-name == "Spinner" || selected-name == "Skeleton" ? "color-primary · bg-disabled · progress/spinner/skeleton-cycle · reduced-motion"
        : "bg-surface/layout · text-primary/secondary/disabled · border-* · fill-* · selection-bg · focus-outline · radius-* · space-*";
    private property <bool> button-page: (page == 0 && section == 7) || page == 2;
    private property <CheckState> checkbox-state: CheckState.checked;
    private property <bool> switch-value: true;
    private property <string> input-value: "SlintUI";
    private property <[string]> options: ["Alpha", "Beta", "Gamma"];
    private property <[PopupMenuEntry]> menu-entries: [
        { text: GalleryStrings.add, shortcut: "Ctrl+N", enabled: true, checked: false, separator: false, has-submenu: false },
        { text: GalleryStrings.settings, shortcut: "", enabled: true, checked: true, separator: false, has-submenu: false },
        { text: GalleryStrings.delete-action, shortcut: "Del", enabled: false, checked: false, separator: false, has-submenu: false },
    ];
    private property <[TabItem]> tabs: [
        { text: GalleryStrings.overview, accessible-name: GalleryStrings.overview, enabled: true, closable: false },
        { text: GalleryStrings.details, accessible-name: GalleryStrings.details, enabled: true, closable: true },
        { text: GalleryStrings.disabled, accessible-name: GalleryStrings.disabled, enabled: false, closable: false },
    ];
    private property <[BreadcrumbItem]> breadcrumbs: [
        { text: GalleryStrings.general, accessible-name: GalleryStrings.general, enabled: true },
        { text: GalleryStrings.navigation, accessible-name: GalleryStrings.navigation, enabled: true },
        { text: selected-name, accessible-name: selected-name, enabled: false },
    ];
    private property <[StepItem]> steps: [
        { title: GalleryStrings.one, description: GalleryStrings.ready, state: StepState.complete, enabled: true },
        { title: GalleryStrings.two, description: GalleryStrings.loading, state: StepState.current, enabled: true },
        { title: GalleryStrings.three, description: GalleryStrings.disabled, state: StepState.waiting, enabled: false },
    ];
    private property <[NavigationRailItem]> rail-items: [
        { text: GalleryStrings.overview, icon: @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/home.svg"), accessible-name: GalleryStrings.overview, enabled: true },
        { text: GalleryStrings.settings, icon: SettingOutlined.source, accessible-name: GalleryStrings.settings, enabled: true },
    ];
    private property <[MultiSelectOption]> multi-options: [
        { text: "Alpha", selected: true, enabled: true }, { text: "Beta", selected: true, enabled: true }, { text: "Gamma", selected: false, enabled: true },
    ];
    private property <[AutoCompleteOption]> suggestions: [
        { text: "SlintUI", detail: GalleryStrings.ready, enabled: true }, { text: "Slint", detail: "1.17.1", enabled: true },
    ];
    private property <[ColorOption]> colors: [
        { name: "Primary", value: Theme.color-primary, enabled: true }, { name: "Success", value: Theme.color-success, enabled: true }, { name: "Error", value: Theme.color-error, enabled: true },
    ];
    private property <[TreeItem]> tree-items: [
        { text: GalleryStrings.settings, accessible-name: GalleryStrings.settings, level: 0, enabled: true, visible: true, has-children: true, expanded: true },
        { text: GalleryStrings.account, accessible-name: GalleryStrings.account, level: 1, enabled: true, visible: true, has-children: false, expanded: false },
    ];
    private property <[TableColumn]> columns: [
        { title: GalleryStrings.user-name, min-width: 140px, width: 180px, horizontal-stretch: 1 },
        { title: GalleryStrings.validation, min-width: 120px, width: 160px, horizontal-stretch: 1 },
    ];
    private property <[[StandardListViewItem]]> rows: [
        [{ text: "SlintUI" }, { text: GalleryStrings.ready }], [{ text: "Desktop" }, { text: GalleryStrings.loading }],
    ];
    private property <[TimelineItem]> timeline-items: [
        { title: GalleryStrings.ready, detail: GalleryStrings.long-text, time: "09:30", tone: TimelineTone.success, enabled: true },
        { title: GalleryStrings.loading, detail: GalleryStrings.account-help, time: "10:00", tone: TimelineTone.info, enabled: true },
    ];
    private property <[string]> weekdays: ["一", "二", "三", "四", "五", "六", "日"];
    private property <[CalendarDay]> days: [
        { label: "1", accessible-name: "1", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "2", accessible-name: "2", in-current-month: true, selected: true, today: true, enabled: true },
        { label: "3", accessible-name: "3", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "4", accessible-name: "4", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "5", accessible-name: "5", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "6", accessible-name: "6", in-current-month: true, selected: false, today: false, enabled: true },
        { label: "7", accessible-name: "7", in-current-month: true, selected: false, today: false, enabled: true },
    ];
    private property <[ToastMessage]> toasts: [
        { id: 1, text: GalleryStrings.ready, detail: GalleryStrings.long-text, tone: ToastTone.success, duration: 0ms, dismissible: true },
    ];
    private property <[ButtonGroupItem]> button-group-items: [
        { text: GalleryStrings.one, enabled: true, checked: false }, { text: GalleryStrings.two, enabled: true, checked: true }, { text: GalleryStrings.disabled, enabled: false, checked: false },
    ];
    private property <[CheckboxGroupItem]> checkbox-group-items: [
        { text: "Alpha", value: "alpha", checked: true, enabled: true }, { text: "Beta", value: "beta", checked: false, enabled: true }, { text: GalleryStrings.disabled, value: "disabled", checked: false, enabled: false },
    ];
    private property <[RadioGroupItem]> radio-group-items: [
        { text: GalleryStrings.one, value: "one", enabled: true }, { text: GalleryStrings.two, value: "two", enabled: true }, { text: GalleryStrings.disabled, value: "disabled", enabled: false },
    ];
    private property <[ListItemData]> list-items: [
        { text: GalleryStrings.account, description: GalleryStrings.account-help, enabled: true }, { text: GalleryStrings.notifications, description: GalleryStrings.long-text, enabled: true }, { text: GalleryStrings.disabled, description: "", enabled: false },
    ];
    private property <[DescriptionItem]> description-items: [
        { label: GalleryStrings.user-name, value: "SlintUI" }, { label: GalleryStrings.validation, value: GalleryStrings.ready }, { label: GalleryStrings.details, value: GalleryStrings.long-text },
    ];
    private property <[CollapseItem]> collapse-items: [
        { title: GalleryStrings.overview, content: GalleryStrings.long-text, enabled: true, expanded: true }, { title: GalleryStrings.details, content: GalleryStrings.account-help, enabled: true, expanded: false }, { title: GalleryStrings.disabled, content: "", enabled: false, expanded: false },
    ];

    out property <length> content-height: content.preferred-height;
    min-width: 680px;
    height: root.content-height;

    content := Stack {
        width: parent.width;
        padding: Theme.space-6;
        gap: Theme.space-4;

        Typography { text: root.selected-name; style: TypographyStyle.title-large; }
        Typography { text: root.button-page ? GalleryStrings.button-description : GalleryStrings.component-description; style: TypographyStyle.body; color: Theme.text-secondary; }
        Typography { text: GalleryStrings.when-to-use; style: TypographyStyle.title-small; }
        Typography { text: root.button-page ? GalleryStrings.button-when-to-use : GalleryStrings.component-when-to-use; style: TypographyStyle.body; }
        Typography { text: GalleryStrings.examples; style: TypographyStyle.title-small; }

        Card {
            width: 840px;
            title: root.button-page ? GalleryStrings.types : GalleryStrings.basic-example;
            description: root.button-page ? GalleryStrings.button-types-help : GalleryStrings.basic-example-help;

            if root.page == 0 && root.section == 0: Stack {
                Space { Label { text: GalleryStrings.theme; muted: true; } Label { text: Theme.mode == ThemeMode.dark ? GalleryStrings.dark : Theme.mode == ThemeMode.high-contrast ? GalleryStrings.contrast : GalleryStrings.light; } }
                Space { Label { text: GalleryStrings.density; muted: true; } Label { text: Theme.density == Density.compact ? GalleryStrings.compact : Theme.density == Density.comfortable ? GalleryStrings.comfortable : GalleryStrings.regular; } }
                Space { Rectangle { width: 64px; height: 32px; background: Theme.color-primary; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-success; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-warning; border-radius: Theme.radius-medium; } Rectangle { width: 64px; height: 32px; background: Theme.color-error; border-radius: Theme.radius-medium; } }
            }
            if root.page == 0 && root.section == 1: Stack { Typography { text: GalleryStrings.title; style: TypographyStyle.title-large; } Typography { text: GalleryStrings.subtitle; style: TypographyStyle.title-medium; } Typography { text: GalleryStrings.long-text; style: TypographyStyle.body; } Typography { text: "Caption · 12 / 20"; style: TypographyStyle.caption; color: Theme.text-secondary; } }
            if root.page == 0 && root.section == 2: Stack { Label { text: GalleryStrings.long-text; } Label { text: GalleryStrings.disabled; muted: true; } }
            if root.page == 0 && root.section == 3: Space { Icon { source: SettingOutlined.source; size: IconSize.large; accessible-name: GalleryStrings.settings; } Icon { source: BellOutlined.source; size: IconSize.medium; accessible-name: GalleryStrings.notifications; } Icon { source: SearchOutlined.source; size: IconSize.small; accessible-name: GalleryStrings.search; } Icon { source: UserOutlined.source; size: IconSize.medium; accessible-name: GalleryStrings.user-name; } }
            if root.page == 0 && root.section == 4: Space { Surface { width: 180px; height: 88px; variant: SurfaceVariant.surface; bordered: true; } Surface { width: 180px; height: 88px; variant: SurfaceVariant.elevated; bordered: true; } Surface { width: 180px; height: 88px; variant: SurfaceVariant.layout; bordered: true; } }
            if root.page == 0 && root.section == 5: Stack { Divider { orientation: DividerOrientation.horizontal; } Space { Label { text: GalleryStrings.one; } Divider { orientation: DividerOrientation.vertical; } Label { text: GalleryStrings.two; } } }
            if root.page == 0 && root.section == 6: Rectangle { width: 180px; height: 48px; background: Theme.bg-control; border-radius: Theme.radius-medium; FocusRing { active: true; target-width: parent.width; target-height: parent.height; } }
            if root.button-page: Space { Button { text: GalleryStrings.save; variant: ButtonVariant.primary; } Button { text: GalleryStrings.cancel; } Button { text: GalleryStrings.delete-action; variant: ButtonVariant.danger; } Button { text: GalleryStrings.text-action; variant: ButtonVariant.text; } Button { text: GalleryStrings.link-action; variant: ButtonVariant.link; } }
            if root.page == 0 && root.section == 8: Space { IconButton { icon: SearchOutlined.source; accessible-name: GalleryStrings.search; tooltip: GalleryStrings.search; } IconButton { icon: SettingOutlined.source; accessible-name: GalleryStrings.settings; enabled: false; } }
            if root.page == 0 && root.section == 9: Space { ToolButton { text: GalleryStrings.save; checkable: true; checked: true; } ToolButton { text: GalleryStrings.notifications; } ToolButton { text: GalleryStrings.disabled; enabled: false; } }
            if root.page == 0 && root.section == 10: Stack { SplitButton { text: GalleryStrings.save; variant: ButtonVariant.primary; menu-entries: root.menu-entries; menu-accessible-name: GalleryStrings.open-menu; } SplitButton { text: GalleryStrings.loading; loading: true; menu-entries: root.menu-entries; menu-accessible-name: GalleryStrings.open-menu; } }
            if root.page == 0 && root.section == 11: Stack { ButtonGroup { width: 420px; items: root.button-group-items; current-index: 1; accessible-name: "ButtonGroup"; } ButtonGroup { width: 420px; items: root.button-group-items; enabled: false; accessible-name: GalleryStrings.disabled; } }
            if root.page == 0 && root.section == 12: Space { ToggleButton { text: GalleryStrings.favorite; checked: true; } ToggleButton { text: GalleryStrings.disabled; enabled: false; } }
