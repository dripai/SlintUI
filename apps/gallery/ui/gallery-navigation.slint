import { Theme, ScrollArea } from "@slint-ui/index.slint";

export struct GalleryNavItem { text: string, page: int, section: int, level: int }

export component GalleryNavigation inherits Rectangle {
    in-out property <int> page: 0;
    in-out property <int> section: 0;
    in property <string> general-text: "";
    in property <string> layout-text: "";
    in property <string> navigation-text: "";
    in property <string> data-entry-text: "";
    in property <string> data-display-text: "";
    in property <string> feedback-text: "";
    in property <string> icons-text: "";

    private property <[GalleryNavItem]> items: [
        { text: general-text, page: 0, section: 0, level: 0 },
        { text: "Theme", page: 0, section: 0, level: 1 }, { text: "Typography", page: 0, section: 1, level: 1 }, { text: "Label", page: 0, section: 2, level: 1 }, { text: "Icon", page: 0, section: 3, level: 1 }, { text: "Button", page: 0, section: 7, level: 1 }, { text: "IconButton", page: 0, section: 8, level: 1 }, { text: "ToolButton", page: 0, section: 9, level: 1 }, { text: "SplitButton", page: 0, section: 10, level: 1 },
        { text: layout-text, page: 1, section: 0, level: 0 },
        { text: "Surface", page: 1, section: 0, level: 1 }, { text: "Divider", page: 1, section: 1, level: 1 }, { text: "FocusRing", page: 1, section: 2, level: 1 }, { text: "Stack", page: 1, section: 3, level: 1 }, { text: "Space", page: 1, section: 4, level: 1 }, { text: "ScrollArea", page: 1, section: 5, level: 1 }, { text: "Overlay", page: 1, section: 6, level: 1 }, { text: "SplitPane", page: 1, section: 7, level: 1 }, { text: "Toolbar", page: 1, section: 8, level: 1 }, { text: "SettingsSection", page: 1, section: 9, level: 1 },
        { text: navigation-text, page: 6, section: 0, level: 0 },
        { text: "Tabs", page: 6, section: 0, level: 1 }, { text: "PopupMenu", page: 6, section: 1, level: 1 }, { text: "ContextMenu", page: 6, section: 2, level: 1 }, { text: "Breadcrumb", page: 6, section: 3, level: 1 }, { text: "Steps", page: 6, section: 4, level: 1 }, { text: "Pagination", page: 6, section: 5, level: 1 }, { text: "NavigationRail", page: 6, section: 6, level: 1 }, { text: "CommandPalette", page: 6, section: 7, level: 1 },
        { text: data-entry-text, page: 3, section: 0, level: 0 },
        { text: "Form", page: 3, section: 0, level: 1 }, { text: "FormRow", page: 3, section: 1, level: 1 }, { text: "Checkbox", page: 3, section: 2, level: 1 }, { text: "Switch", page: 3, section: 3, level: 1 }, { text: "TextField", page: 3, section: 4, level: 1 }, { text: "Select", page: 3, section: 5, level: 1 }, { text: "MultiSelect", page: 3, section: 6, level: 1 }, { text: "AutoComplete", page: 3, section: 7, level: 1 }, { text: "DatePicker", page: 3, section: 8, level: 1 }, { text: "TimePicker", page: 3, section: 9, level: 1 }, { text: "ColorPicker", page: 3, section: 10, level: 1 },
        { text: data-display-text, page: 7, section: 0, level: 0 },
        { text: "Card", page: 7, section: 0, level: 1 }, { text: "SegmentedControl", page: 7, section: 1, level: 1 }, { text: "Tooltip", page: 7, section: 2, level: 1 }, { text: "Table", page: 7, section: 3, level: 1 }, { text: "Tree", page: 7, section: 4, level: 1 }, { text: "Avatar", page: 7, section: 5, level: 1 }, { text: "DataGrid", page: 7, section: 6, level: 1 }, { text: "Statistic", page: 7, section: 7, level: 1 }, { text: "Timeline", page: 7, section: 8, level: 1 }, { text: "ImageView", page: 7, section: 9, level: 1 }, { text: "Calendar", page: 7, section: 10, level: 1 }, { text: "EmptyState", page: 7, section: 11, level: 1 },
        { text: feedback-text, page: 4, section: 0, level: 0 },
        { text: "Progress", page: 4, section: 0, level: 1 }, { text: "Spinner", page: 4, section: 1, level: 1 }, { text: "StatusBar", page: 4, section: 2, level: 1 }, { text: "Toast", page: 4, section: 3, level: 1 }, { text: "ModalDialog", page: 4, section: 4, level: 1 }, { text: "ConfirmDialog", page: 4, section: 5, level: 1 }, { text: "Notification", page: 4, section: 6, level: 1 }, { text: "Drawer", page: 4, section: 7, level: 1 }, { text: "Skeleton", page: 4, section: 8, level: 1 },
        { text: icons-text, page: 5, section: 0, level: 0 },
        { text: "Outlined", page: 5, section: 0, level: 1 }, { text: "Filled", page: 5, section: 1, level: 1 },
    ];

    background: Theme.bg-surface;
    accessible-role: list;

    ScrollArea {
        width: parent.width;
        height: parent.height;
        mouse-drag-pan-enabled: false;
        VerticalLayout {
            spacing: Theme.space-1;
            for item in root.items: Rectangle {
                visible: item.level == 0 || item.page == root.page;
                min-height: self.visible ? (item.level == 0 ? Theme.control-height-large : Theme.control-height-medium) : 0px;
                max-height: self.visible ? (item.level == 0 ? Theme.control-height-large : Theme.control-height-medium) : 0px;
                vertical-stretch: 0;
                background: item.level == 1 && item.page == root.page && item.section == root.section ? Theme.selection-bg : touch.has-hover ? Theme.fill-hover : transparent;
                border-radius: Theme.radius-medium;
                accessible-role: list-item;
                accessible-label: item.text;
                accessible-action-default => { root.select(item.page, item.section); }

                HorizontalLayout {
                    padding-left: item.level == 0 ? Theme.space-3 : Theme.space-8;
                    padding-right: Theme.space-2;
                    spacing: Theme.space-2;
                    cross-axis-alignment: center;
                    if item.level == 0: Image {
                        width: Theme.icon-size-x-small; height: Theme.icon-size-x-small;
                        source: item.page == root.page ? @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/down.svg") : @image-url("../../../crates/slint-ui/assets/icons/ant-design/outlined/right.svg");
                        colorize: Theme.icon-default; accessible-role: none;
                    }
                    Text { text: item.text; color: Theme.text-primary; font-size: Theme.font-size-body; font-weight: item.level == 0 ? Theme.font-weight-medium : Theme.font-weight-regular; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                }
                touch := TouchArea { clicked => { root.select(item.page, item.section); } }
            }
        }
    }

    public function select(next-page: int, next-section: int) {
        root.page = next-page;
        root.section = next-section;
    }
}
