import { Theme } from "@slint-ui/index.slint";

export global GalleryStrings {
    out property <bool> english: Theme.locale == "en-US";
    out property <bool> arabic: Theme.locale == "ar-EG";

    out property <string> title: arabic ? "معرض SlintUI" : english ? "SlintUI Gallery" : "SlintUI 组件展示";
    out property <string> subtitle: arabic ? "مرجع مكونات سطح المكتب" : english ? "Desktop component reference" : "桌面组件交互与视觉基线";
    out property <string> foundations: arabic ? "الأساسيات" : english ? "Foundations" : "基础";
    out property <string> layout: arabic ? "التخطيط" : english ? "Layout" : "布局";
    out property <string> actions: arabic ? "الإجراءات" : english ? "Actions" : "操作";
    out property <string> inputs: arabic ? "الإدخال" : english ? "Inputs" : "输入";
    out property <string> feedback: arabic ? "الملاحظات" : english ? "Feedback" : "反馈";
    out property <string> icons: arabic ? "الأيقونات" : english ? "Icons" : "图标";
    out property <string> outlined: arabic ? "مخطط" : english ? "Outlined" : "线性";
    out property <string> filled: arabic ? "ممتلئ" : english ? "Filled" : "填充";
    out property <string> icon-catalog-description: arabic ? "696 مورداً متجهاً، يتم استيرادها عند الطلب." : english ? "696 vector assets with per-icon imports." : "696 个矢量资源，支持逐图标按需导入。";
    out property <string> theme: arabic ? "السمة" : english ? "Theme" : "主题";
    out property <string> density: arabic ? "الكثافة" : english ? "Density" : "密度";
    out property <string> scale: arabic ? "التكبير" : english ? "Scale" : "缩放";
    out property <string> locale: arabic ? "اللغة" : english ? "Locale" : "语言";
    out property <string> light: arabic ? "فاتح" : english ? "Light" : "浅色";
    out property <string> dark: arabic ? "داكن" : english ? "Dark" : "深色";
    out property <string> contrast: arabic ? "تباين" : english ? "Contrast" : "高对比度";
    out property <string> compact: arabic ? "مضغوط" : english ? "Compact" : "紧凑";
    out property <string> regular: arabic ? "عادي" : english ? "Regular" : "常规";
    out property <string> comfortable: arabic ? "مريح" : english ? "Comfort" : "宽松";
    out property <string> save: arabic ? "حفظ" : english ? "Save" : "保存";
    out property <string> delete-action: arabic ? "حذف" : english ? "Delete" : "删除";
    out property <string> cancel: arabic ? "إلغاء" : english ? "Cancel" : "取消";
    out property <string> account: arabic ? "الحساب" : english ? "Account" : "账户";
    out property <string> account-help: arabic ? "تُستخدم هذه المعلومات للمزامنة." : english ? "This information is used for synchronization." : "这些信息用于同步设置。";
    out property <string> user-name: arabic ? "اسم المستخدم" : english ? "User name" : "用户名";
    out property <string> user-name-placeholder: arabic ? "أدخل اسم المستخدم" : english ? "Enter a user name" : "请输入用户名";
    out property <string> update: arabic ? "التحديث التلقائي" : english ? "Automatic updates" : "自动更新";
    out property <string> notifications: arabic ? "الإشعارات" : english ? "Notifications" : "通知";
    out property <string> choose: arabic ? "اختيار" : english ? "Choose" : "选择";
    out property <string> loading: arabic ? "جارٍ التحميل" : english ? "Loading" : "正在加载";
    out property <string> empty-title: arabic ? "لا توجد بيانات" : english ? "No data" : "暂无数据";
    out property <string> empty-description: arabic ? "أضف عنصرًا للبدء." : english ? "Add an item to get started." : "添加一个项目后即可开始。";
    out property <string> ready: arabic ? "جاهز" : english ? "Ready" : "就绪";
    out property <string> shortcut-help: arabic ? "حفظ التغييرات" : english ? "Save changes" : "保存更改";
    out property <string> settings: arabic ? "الإعدادات" : english ? "Settings" : "设置";
    out property <string> add: arabic ? "إضافة" : english ? "Add" : "添加";
    out property <string> one: arabic ? "واحد" : english ? "One" : "一";
    out property <string> two: arabic ? "اثنان" : english ? "Two" : "二";
    out property <string> three: arabic ? "ثلاثة" : english ? "Three" : "三";
    out property <string> button-states: arabic ? "حالات الزر" : english ? "Button states" : "按钮状态";
    out property <string> text-action: arabic ? "نص" : english ? "Text" : "文本";
    out property <string> link-action: arabic ? "رابط" : english ? "Link" : "链接";
    out property <string> small: arabic ? "صغير" : english ? "Small" : "小";
    out property <string> medium: arabic ? "متوسط" : english ? "Medium" : "中";
    out property <string> large: arabic ? "كبير" : english ? "Large" : "大";
    out property <string> sample-toolbar: arabic ? "شريط أدوات نموذجي" : english ? "Sample toolbar" : "示例工具栏";
    out property <string> indeterminate: arabic ? "غير محدد" : english ? "Indeterminate" : "不确定";
    out property <string> disabled: arabic ? "معطل" : english ? "Disabled" : "已禁用";
    out property <string> view-mode: arabic ? "وضع العرض" : english ? "View mode" : "视图模式";
    out property <string> validation: arabic ? "التحقق" : english ? "Validation" : "校验";
    out property <string> invalid-value: arabic ? "قيمة غير صالحة" : english ? "Invalid value" : "值无效";
    out property <string> select-label: arabic ? "اختيار" : english ? "Select" : "选择器";
    out property <string> progress-label: arabic ? "التقدم" : english ? "Progress" : "进度";
    out property <string> search: arabic ? "بحث" : english ? "Search" : "搜索";
    out property <string> favorite: arabic ? "مفضلة" : english ? "Favorite" : "收藏";
    out property <string> desktop: arabic ? "سطح المكتب" : english ? "Desktop P1" : "桌面 P1";
    out property <string> advanced: arabic ? "مكونات متقدمة" : english ? "Advanced P2" : "进阶 P2";
    out property <string> overview: arabic ? "نظرة عامة" : english ? "Overview" : "概览";
    out property <string> details: arabic ? "التفاصيل" : english ? "Details" : "详情";
    out property <string> open-menu: arabic ? "فتح القائمة" : english ? "Open menu" : "打开菜单";
    out property <string> resize-pane: arabic ? "تغيير حجم اللوحة" : english ? "Resize pane" : "调整分栏";
    out property <string> fix-errors: arabic ? "أصلح الأخطاء التالية" : english ? "Fix the following errors" : "请修复以下错误";
    out property <string> dialog-host-note: arabic ? "يتم فتح مربع الحوار العلوي بواسطة المضيف." : english ? "The top-level dialog is opened by the host." : "顶层对话框由宿主创建并打开。";
    out property <string> long-text: arabic ? "نص طويل للتحقق من الالتفاف والاتجاه وإمكانية القراءة." : english ? "A deliberately long sentence validates wrapping, direction, and readability." : "这是一段用于验证换行、文字方向和可读性的较长中文说明。";
    out property <string> previous: arabic ? "السابق" : english ? "Previous" : "上一个";
    out property <string> next: arabic ? "التالي" : english ? "Next" : "下一个";
    out property <string> year: arabic ? "السنة" : english ? "Year" : "年";
    out property <string> month: arabic ? "الشهر" : english ? "Month" : "月";
    out property <string> day: arabic ? "اليوم" : english ? "Day" : "日";
}
