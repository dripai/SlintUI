    out property <string> dialog-host-note: arabic ? "يتم فتح مربع الحوار العلوي بواسطة المضيف." : english ? "The top-level dialog is opened by the host." : "顶层对话框由宿主创建并打开。";
    out property <string> long-text: arabic ? "نص طويل للتحقق من الالتفاف والاتجاه وإمكانية القراءة." : english ? "A deliberately long sentence validates wrapping, direction, and readability." : "这是一段用于验证换行、文字方向和可读性的较长中文说明。";
    out property <string> previous: arabic ? "السابق" : english ? "Previous" : "上一个";
