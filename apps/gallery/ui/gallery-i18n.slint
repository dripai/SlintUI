    out property <string> month: arabic ? "الشهر" : english ? "Month" : "月";
    out property <string> day: arabic ? "اليوم" : english ? "Day" : "日";
    out property <string> component-description: arabic ? "مكوّن سطح مكتب قابل لإعادة الاستخدام يتبع السمة والتفاعل وإمكانية الوصول." : english ? "A reusable desktop component governed by the shared theme, interaction, and accessibility rules." : "遵循统一主题、交互和无障碍规范的可复用桌面组件。";
    out property <string> component-when-to-use: arabic ? "استخدمه عندما تتطابق دلالة المكوّن مع مهمة المستخدم، ولا تستبدله بمكوّن مشابه بصمت." : english ? "Use it when its semantics match the user task; do not silently substitute a similar component." : "当组件语义与用户任务一致时使用，不使用相似组件静默替代。";
    out property <string> button-description: arabic ? "يُستخدم لتشغيل عملية أو سلسلة عمليات." : english ? "Triggers an operation or a series of operations." : "用于触发一个操作或一组操作。";
    out property <string> button-when-to-use: arabic ? "استخدم زرًا أساسيًا واحدًا كحد أقصى في المنطقة، وضع العمليات الأخرى في أزرار ثانوية أو قائمة." : english ? "Use at most one primary button in a region; place other actions in secondary buttons or a menu." : "一个区域最多使用一个主按钮，其他操作使用次按钮或收纳到菜单。";
    out property <string> when-to-use: arabic ? "متى يُستخدم" : english ? "When to use" : "何时使用";
    out property <string> examples: arabic ? "أمثلة" : english ? "Examples" : "示例";
    out property <string> basic-example: arabic ? "مثال أساسي" : english ? "Basic" : "基础示例";
    out property <string> basic-example-help: arabic ? "مثال واحد يوضح الاستخدام الأساسي دون خلط مهام أخرى." : english ? "A focused example of the component's primary use." : "仅展示组件的主要用途，不混入其他任务。";
    out property <string> types: arabic ? "الأنواع" : english ? "Types" : "按钮类型";
    out property <string> button-types-help: arabic ? "اختر النمط حسب أولوية العملية ومخاطرها." : english ? "Choose a variant according to action priority and risk." : "根据操作优先级和风险选择按钮类型。";
    out property <string> sizes-and-states: arabic ? "الأحجام والحالات" : english ? "Sizes and states" : "尺寸与状态";
    out property <string> button-states-help: arabic ? "ثلاثة أحجام وحالات الأيقونة والتحميل والتعطيل." : english ? "Three sizes plus icon, loading, and disabled states." : "展示三种尺寸，以及图标、加载和禁用状态。";
    out property <string> api-and-limits: arabic ? "واجهة API والحدود" : english ? "API and limits" : "API 与限制";
    out property <string> api-help: arabic ? "الخصائص العامة ومسؤوليات المضيف موثقة في مواصفات المكوّن." : english ? "Public properties and host responsibilities are documented in the component specification." : "公开属性和宿主职责以组件规格文档为准。";
    out property <string> component-api-note: arabic ? "تستخدم المكوّنات قيم Theme ولا تحتوي على نصوص عمل أو واجهات نظام أساسي." : english ? "Components consume Theme tokens and do not embed business copy or platform APIs." : "组件只消费 Theme Token，不内置业务文案或平台 API。";
    out property <string> theme-token: arabic ? "رموز السمة" : english ? "Theme Token" : "主题 Token";
    out property <string> theme-token-help: arabic ? "قيم دلالية مشتركة يستخدمها المكوّن، ولا تُنسخ داخل التنفيذ." : english ? "Shared semantic values consumed by the component instead of copied into its implementation." : "组件消费的共享语义值，不在实现内部重复定义。";
}
