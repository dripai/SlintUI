import { Theme, Direction } from "../tokens/theme.slint";

export struct DescriptionItem { label: string, value: string }

export component DescriptionList inherits Rectangle {
    in property <[DescriptionItem]> items;
    in property <length> label-width: Theme.control-min-width;
    in property <bool> bordered: false;
    in property <string> accessible-name: "";

    min-width:Theme.card-min-width; background:Theme.bg-surface; border-width:bordered?Theme.border-width:0px; border-color:Theme.border-default; border-radius:Theme.radius-medium;
    accessible-role:groupbox; accessible-label:accessible-name; accessible-item-count:items.length;
    VerticalLayout { spacing:0px;
        for item[index] in root.items: Rectangle { min-height:max(Theme.row-height,row.preferred-height); border-width:root.bordered?Theme.border-width:0px; border-color:Theme.border-secondary;
            row:=HorizontalLayout{padding-left:Theme.space-3;padding-right:Theme.space-3;padding-top:Theme.space-2;padding-bottom:Theme.space-2;spacing:Theme.space-3;cross-axis-alignment:start;
                Text{min-width:root.label-width;max-width:root.label-width;text:item.label;color:Theme.text-secondary;font-size:Theme.font-size-body;font-weight:Theme.font-weight-medium;horizontal-alignment:Theme.direction==Direction.rtl?right:left;wrap:word-wrap;}
                Text{text:item.value;color:Theme.text-primary;font-size:Theme.font-size-body;horizontal-stretch:1;horizontal-alignment:Theme.direction==Direction.rtl?right:left;wrap:word-wrap;}
            }
        }
    }
}
