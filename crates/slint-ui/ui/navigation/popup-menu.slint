import { ScrollView } from "std-widgets.slint";
import { Theme } from "../tokens/theme.slint";

export struct PopupMenuEntry {
    text: string,
    shortcut: string,
    enabled: bool,
    checked: bool,
    separator: bool,
    has-submenu: bool,
}

export component PopupMenuItem inherits Rectangle {
    in property <PopupMenuEntry> entry;
    in property <string> accessible-name: entry.text;
    in property <bool> highlighted: false;

    callback triggered();
    callback submenu-requested();

    min-width: Theme.popup-min-width;
    min-height: entry.separator ? Theme.space-2 : Theme.row-height;
    background: !entry.separator && entry.enabled && (highlighted || touch.has-hover) ? Theme.fill-hover : transparent;
    accessible-role: list-item;
    accessible-label: accessible-name;
    accessible-enabled: entry.enabled;
    accessible-checkable: !entry.separator;
    accessible-checked: entry.checked;
    accessible-expandable: entry.has-submenu;
    accessible-action-default => { root.activate(); }
    accessible-action-expand => { if (entry.enabled && entry.has-submenu) { root.submenu-requested(); } }

    public function activate() {
        if (entry.enabled && !entry.separator) {
            if (entry.has-submenu) { root.submenu-requested(); }
            else { root.triggered(); }
        }
    }

    if entry.separator: Rectangle {
        x: Theme.space-2;
        y: (parent.height - self.height) / 2;
        width: parent.width - Theme.space-4;
        height: Theme.border-width;
        background: Theme.border-secondary;
    }

    if !entry.separator: HorizontalLayout {
        padding-left: Theme.space-3;
        padding-right: Theme.space-3;
        spacing: Theme.space-2;
        cross-axis-alignment: center;

        Rectangle {
            width: Theme.icon-size-small;
            height: Theme.icon-size-small;
            if entry.checked: Image {
                width: Theme.icon-size-small;
                height: Theme.icon-size-small;
                source: @image-url("../../assets/icons/ant-design/outlined/check.svg");
                colorize: Theme.color-primary;
                accessible-role: none;
            }
        }

        Text {
            text: entry.text;
            color: entry.enabled ? Theme.text-primary : Theme.text-disabled;
            font-size: Theme.font-size-body;
            horizontal-stretch: 1;
            overflow: elide;
            vertical-alignment: center;
            accessible-role: none;
        }

        if entry.shortcut != "": Text {
            text: entry.shortcut;
            color: entry.enabled ? Theme.text-tertiary : Theme.text-disabled;
            font-size: Theme.font-size-caption;
            vertical-alignment: center;
            accessible-role: none;
        }

        if entry.has-submenu: Image {
            width: Theme.icon-size-x-small;
            height: Theme.icon-size-x-small;
            source: @image-url("../../assets/icons/ant-design/outlined/right.svg");
            colorize: entry.enabled ? Theme.icon-default : Theme.text-disabled;
            accessible-role: none;
        }
    }

    touch := TouchArea {
        enabled: entry.enabled && !entry.separator;
        mouse-cursor: self.enabled ? pointer : default;
        clicked => { root.activate(); }
    }
}

export component PopupMenu inherits Rectangle {
    in property <[PopupMenuEntry]> entries;
    in property <string> accessible-name: "";
    in property <length> popup-width: max(self.width, Theme.popup-min-width);
    in property <length> popup-height: min(Theme.popup-max-height, entries.length * Theme.row-height + Theme.space-2);
    out property <bool> open: menu.is-open;
    in-out property <int> current-index: -1;

    callback selected(index: int);
    callback submenu-requested(index: int);
    callback closed();

    accessible-role: list;
    accessible-label: accessible-name;
    accessible-expandable: true;
    accessible-expanded: open;
    accessible-action-expand => { root.show(); }

    changed open => {
        if (!root.open) { root.closed(); }
    }

    public function show() {
        menu.show();
    }

    public function close() {
        menu.close();
    }

    public function activate(index: int) {
        if (index >= 0 && index < entries.length && entries[index].enabled && !entries[index].separator) {
            if (entries[index].has-submenu) { root.submenu-requested(index); }
            else { root.selected(index); root.close(); }
        }
    }

    menu := PopupWindow {
        x: 0px;
        y: root.height;
        width: root.popup-width;
        height: root.popup-height;
        close-policy: close-on-click-outside;
        forward-focus: popup-focus;

        Rectangle {
            background: Theme.bg-elevated;
            border-width: Theme.border-width;
            border-color: Theme.border-default;
            border-radius: Theme.radius-large;
            clip: true;

            ScrollView {
                VerticalLayout {
                    padding-top: Theme.space-1;
                    padding-bottom: Theme.space-1;
                    spacing: 0px;

                    for entry[index] in root.entries: PopupMenuItem {
                        entry: entry;
                        highlighted: index == root.current-index;
                        triggered => { root.activate(index); }
                        submenu-requested => { root.submenu-requested(index); }
                    }
                }
            }
        }

        popup-focus := FocusScope {
            key-pressed(event) => {
                if (event.text == Key.Escape) { root.close(); return accept; }
                if (event.text == Key.DownArrow) {
                    root.current-index = min(root.entries.length - 1, root.current-index + 1);
                    return accept;
                }
                if (event.text == Key.UpArrow) {
                    root.current-index = max(0, root.current-index - 1);
                    return accept;
                }
                if (event.text == Key.Home) { root.current-index = 0; return accept; }
                if (event.text == Key.End) { root.current-index = root.entries.length - 1; return accept; }
                if (event.text == Key.Return || event.text == Key.Space) { root.activate(root.current-index); return accept; }
                if (event.text == Key.RightArrow && root.current-index >= 0 && root.entries[root.current-index].has-submenu) {
                    root.submenu-requested(root.current-index);
                    return accept;
                }
                return reject;
            }
        }
    }
}
