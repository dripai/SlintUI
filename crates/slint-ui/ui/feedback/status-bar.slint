import { Theme } from "../tokens/theme.slint";
import { Spinner, SpinnerSize } from "spinner.slint";

export enum StatusTone { neutral, info, success, warning, error }

export component StatusBar inherits Rectangle {
    in property <string> text: "";
    in property <string> detail: "";
    in property <StatusTone> tone: StatusTone.neutral;
    in property <bool> busy: false;
    in property <string> accessible-name: text;

    min-height: Theme.row-height;
    preferred-height: Theme.row-height;
    background: Theme.bg-surface;
    border-width: Theme.border-width;
    border-color: Theme.border-secondary;
    accessible-role: content-info;
    accessible-label: accessible-name;
    accessible-description: detail;
    accessible-live-region: polite;

    HorizontalLayout {
        padding-left: Theme.space-3;
        padding-right: Theme.space-3;
        spacing: Theme.space-2;
        cross-axis-alignment: center;

        if root.busy: Spinner {
            size: SpinnerSize.small;
            accessible-name: root.accessible-name;
        }

        if !root.busy: Rectangle {
            width: Theme.status-indicator-size;
            height: Theme.status-indicator-size;
            border-radius: self.width / 2;
            background: root.tone == StatusTone.info ? Theme.color-primary
                : root.tone == StatusTone.success ? Theme.color-success
                : root.tone == StatusTone.warning ? Theme.color-warning
                : root.tone == StatusTone.error ? Theme.color-error
                : Theme.icon-default;
        }

        Text {
            text: root.text;
            color: Theme.text-primary;
            font-size: Theme.font-size-caption;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }

        if root.detail != "": Text {
            text: root.detail;
            color: Theme.text-secondary;
            font-size: Theme.font-size-caption;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}
