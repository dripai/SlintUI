import { Theme, Direction } from "../tokens/theme.slint";

export enum DrawerSide { start, end }

export component Drawer inherits Rectangle {
    in property <bool> open: false;
    in property <DrawerSide> side: DrawerSide.end;
    in property <length> panel-width: Theme.drawer-width;
    in property <string> title: "";
    in property <string> accessible-name: title;
    in property <string> close-accessible-name: "";
    in property <bool> dismiss-on-mask: true;
    in property <bool> close-on-escape: true;
    callback close-requested();

    visible: open;
    background: Theme.overlay-mask;
    accessible-role: region;
    accessible-label: accessible-name;
    accessible-enabled: open;

    private property <bool> physical-left: side == DrawerSide.start ? Theme.direction == Direction.ltr : Theme.direction == Direction.rtl;

    TouchArea { enabled: root.open && root.dismiss-on-mask; clicked => { root.close-requested(); } }

    panel := Rectangle {
        x: root.physical-left ? 0px : root.width - self.width;
        width: min(root.panel-width, root.width);
        height: root.height;
        background: Theme.bg-elevated;
        border-width: Theme.border-width;
        border-color: Theme.border-default;
        accessible-role: groupbox;
        accessible-label: root.accessible-name;

        VerticalLayout {
            HorizontalLayout { padding: Theme.space-4; spacing: Theme.space-2; cross-axis-alignment: center;
                Text { text: root.title; color: Theme.text-primary; font-size: Theme.font-size-title-small; font-weight: Theme.font-weight-medium; horizontal-stretch: 1; overflow: elide; }
                Rectangle { width: Theme.control-height-small; height: Theme.control-height-small; border-radius: Theme.radius-small; background: close-touch.has-hover ? Theme.fill-hover : transparent; accessible-role: button; accessible-label: root.close-accessible-name; accessible-action-default => { root.close-requested(); }
                    Image { source: @image-url("../../assets/icons/ant-design/outlined/close.svg"); width: Theme.icon-size-x-small; height: Theme.icon-size-x-small; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; colorize: Theme.icon-default; accessible-role: none; }
                    close-touch := TouchArea { clicked => { root.close-requested(); } }
                }
            }
            Rectangle { height: Theme.border-width; background: Theme.border-secondary; }
            @children
        }
    }

    FocusScope { enabled: root.open; key-pressed(event) => { if (event.text == Key.Escape && root.close-on-escape) { root.close-requested(); return accept; } return reject; } }
}
