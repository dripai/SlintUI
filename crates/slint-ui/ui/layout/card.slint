import { Theme, Direction } from "../tokens/theme.slint";

export component Card inherits Rectangle {
    in property <string> title: "";
    in property <string> description: "";

    background: Theme.bg-surface;
    border-width: Theme.border-width;
    border-color: Theme.border-default;
    border-radius: Theme.radius-large;
    min-width: Theme.card-min-width;

    VerticalLayout {
        padding: Theme.space-4;
        spacing: Theme.space-3;
        alignment: start;

        if root.title != "": Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: Theme.font-size-title-small;
            font-weight: Theme.font-weight-medium;
            min-height: Theme.line-height-title-small;
            horizontal-alignment: Theme.direction == Direction.rtl ? right : left;
            wrap: word-wrap;
        }

        if root.description != "": Text {
            text: root.description;
            color: Theme.text-secondary;
            font-size: Theme.font-size-body;
            min-height: Theme.line-height-body;
            horizontal-alignment: Theme.direction == Direction.rtl ? right : left;
            wrap: word-wrap;
        }

        @children
    }
}
